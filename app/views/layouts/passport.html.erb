<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Bicycle Passport - Today Bike" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="h-full">
    <div class="min-h-full">
      <header class="bg-white border-b border-gray-200">
        <div class="max-w-2xl mx-auto px-4 py-4 flex items-center gap-2">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
          <span class="text-lg font-bold text-gray-900">Today.bike</span>
          <span class="text-sm text-gray-500 ml-1">Bicycle Passport</span>
        </div>
      </header>

      <main class="max-w-2xl mx-auto px-4 py-6">
        <%= yield %>
      </main>

      <footer class="max-w-2xl mx-auto px-4 py-6 text-center">
        <p class="text-xs text-gray-400">Today.bike - Bicycle Maintenance Shop</p>
      </footer>
    </div>
  </body>
</html>
