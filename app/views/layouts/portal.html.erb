<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Today Bike" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full flex flex-col">
    <a href="#portal-main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-slate-900 focus:shadow-lg">
      본문으로 건너뛰기
    </a>
    <%# Header %>
    <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
      <div class="mx-auto flex max-w-lg items-center justify-between px-4 py-3 lg:max-w-5xl">
        <% if current_customer %>
          <%= link_to portal_root_path, class: "flex items-center gap-2" do %>
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            <span class="text-lg font-bold text-gray-900">Today.bike</span>
          <% end %>
        <% else %>
          <%= link_to root_path, class: "flex items-center gap-2" do %>
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            <span class="text-lg font-bold text-gray-900">Today.bike</span>
          <% end %>
        <% end %>

        <% if current_customer %>
          <div class="flex items-center gap-3">
            <span class="text-sm text-gray-600"><%= current_customer.name %></span>
            <%= button_to portal_logout_path, method: :delete, class: "rounded-full p-1 text-sm text-gray-400 transition hover:text-gray-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600", "aria-label": "로그아웃" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1" />
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    </header>

    <%# Main content %>
    <main id="portal-main" class="mx-auto flex-1 w-full max-w-lg px-4 py-4 pb-[calc(6rem+env(safe-area-inset-bottom))] lg:max-w-5xl">
      <% if notice.present? %>
        <div class="mb-4 rounded-lg bg-green-50 p-3">
          <p class="text-sm text-green-700"><%= notice %></p>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mb-4 rounded-lg bg-red-50 p-3">
          <p class="text-sm text-red-700"><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <% if current_customer %>
      <%# Bottom navigation bar for mobile %>
      <nav class="fixed bottom-0 inset-x-0 bg-white border-t border-gray-200 z-30" aria-label="Portal navigation">
        <div class="mx-auto flex max-w-lg justify-around py-2 pb-[calc(0.5rem+env(safe-area-inset-bottom))] lg:max-w-5xl">
          <%= link_to portal_bicycles_path, class: "flex flex-col items-center gap-1 rounded-xl px-3 py-1 text-xs transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 #{'bg-blue-50 text-blue-700 font-semibold' if controller_name == 'bicycles'} #{'text-gray-500' unless controller_name == 'bicycles'}", aria: ({ current: ("page" if controller_name == "bicycles") }.compact) do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            <span>내 자전거</span>
          <% end %>

          <%= link_to portal_service_orders_path, class: "flex flex-col items-center gap-1 rounded-xl px-3 py-1 text-xs transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 #{'bg-blue-50 text-blue-700 font-semibold' if controller_name == 'service_orders'} #{'text-gray-500' unless controller_name == 'service_orders'}", aria: ({ current: ("page" if controller_name == "service_orders") }.compact) do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            <span>정비이력</span>
          <% end %>

          <%= link_to portal_fitting_records_path, class: "flex flex-col items-center gap-1 rounded-xl px-3 py-1 text-xs transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 #{'bg-blue-50 text-blue-700 font-semibold' if controller_name == 'fitting_records'} #{'text-gray-500' unless controller_name == 'fitting_records'}", aria: ({ current: ("page" if controller_name == "fitting_records") }.compact) do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span>피팅</span>
          <% end %>

          <%= link_to portal_updates_path, class: "flex flex-col items-center gap-1 rounded-xl px-3 py-1 text-xs transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 #{'bg-blue-50 text-blue-700 font-semibold' if controller_name == 'updates'} #{'text-gray-500' unless controller_name == 'updates'}", data: { testid: "nav-updates" }, aria: ({ current: ("page" if controller_name == "updates") }.compact) do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V4a2 2 0 10-4 0v1.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0m6 0H9" />
            </svg>
            <span>업데이트</span>
          <% end %>
        </div>
      </nav>
    <% end %>
  </body>
</html>
