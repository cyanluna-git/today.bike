<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Admin - Today Bike" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full" data-controller="sidebar">
    <div class="min-h-full flex">
      <%# Mobile overlay %>
      <div data-sidebar-target="overlay"
           data-action="click->sidebar#close"
           class="hidden fixed inset-0 bg-gray-900/50 z-30 lg:hidden"></div>

      <%# Sidebar %>
      <aside data-sidebar-target="sidebar"
             class="w-64 bg-gray-900 text-white flex flex-col min-h-screen fixed inset-y-0 left-0 z-40 transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-in-out">
        <div class="px-6 py-5 border-b border-gray-700 flex items-center justify-between">
          <div>
            <h1 class="text-lg font-bold tracking-wide">Today Bike</h1>
            <p class="text-xs text-gray-400 mt-0.5">Admin Panel</p>
          </div>
          <%# Close button for mobile %>
          <button data-action="sidebar#close" class="lg:hidden text-gray-400 hover:text-white transition" aria-label="Close sidebar">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <%= link_to admin_root_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'dashboard'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
            </svg>
            대시보드
          <% end %>

          <%= link_to admin_customers_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'customers'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            고객관리
          <% end %>

          <%= link_to admin_bicycles_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'bicycles'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            자전거관리
          <% end %>

          <%= link_to admin_service_orders_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'service_orders' && action_name != 'kanban'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            서비스오더
          <% end %>

          <%= link_to kanban_admin_service_orders_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'service_orders' && action_name == 'kanban'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
            </svg>
            칸반보드
          <% end %>

          <%= link_to admin_bicycles_path(anchor: "fitting"), data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'fitting_records'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            피팅기록
          <% end %>

          <%= link_to admin_products_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'products'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            파츠/용품
          <% end %>

          <%= link_to admin_service_inquiries_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'service_inquiries'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4v-4z" />
            </svg>
            문의 접수
          <% end %>

          <%= link_to admin_rentals_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'rentals' || controller_name == 'rental_bookings'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            대여관리
          <% end %>

          <%= link_to admin_blog_posts_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'blog_posts'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            블로그 관리
          <% end %>

          <%= link_to new_admin_import_path, data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'imports'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            데이터 가져오기
          <% end %>
        </nav>

        <div class="px-4 py-4 border-t border-gray-700">
          <div class="px-3 py-2 text-xs text-gray-400 truncate mb-2">
            <%= current_admin_user.email %>
          </div>
          <%= button_to destroy_admin_user_session_path, method: :delete, class: "w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1" />
            </svg>
            Log out
          <% end %>
        </div>
      </aside>

      <%# Main content %>
      <main class="flex-1 lg:ml-64">
        <%# Mobile top bar with hamburger %>
        <div class="lg:hidden sticky top-0 z-20 bg-gray-900 px-4 py-3 flex items-center gap-3">
          <button data-action="sidebar#toggle" class="text-white hover:text-gray-300 transition" aria-label="Toggle sidebar">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <h1 class="text-white text-sm font-bold tracking-wide">Today Bike</h1>
        </div>

        <div class="px-4 sm:px-6 lg:px-8 py-6">
          <% if notice.present? %>
            <div class="mb-4 rounded-md bg-green-50 p-4">
              <p class="text-sm text-green-700"><%= notice %></p>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="mb-4 rounded-md bg-red-50 p-4">
              <p class="text-sm text-red-700"><%= alert %></p>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
