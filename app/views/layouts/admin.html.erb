<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Admin - Today Bike" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <div class="min-h-full flex">
      <%# Sidebar %>
      <aside class="w-64 bg-gray-900 text-white flex flex-col min-h-screen fixed inset-y-0 left-0">
        <div class="px-6 py-5 border-b border-gray-700">
          <h1 class="text-lg font-bold tracking-wide">Today Bike</h1>
          <p class="text-xs text-gray-400 mt-0.5">Admin Panel</p>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-1">
          <%= link_to admin_root_path, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'dashboard'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
            </svg>
            Dashboard
          <% end %>

          <%= link_to admin_customers_path, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'customers'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Customers
          <% end %>

          <%= link_to admin_bicycles_path, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'bicycles'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            Bicycles
          <% end %>

          <%= link_to admin_service_orders_path, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'service_orders' && action_name != 'kanban'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            서비스오더
          <% end %>

          <%= link_to kanban_admin_service_orders_path, class: "flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium #{'bg-gray-800 text-white' if controller_name == 'service_orders' && action_name == 'kanban'} hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
            </svg>
            칸반보드
          <% end %>
        </nav>

        <div class="px-4 py-4 border-t border-gray-700">
          <div class="px-3 py-2 text-xs text-gray-400 truncate mb-2">
            <%= current_admin_user.email %>
          </div>
          <%= button_to destroy_admin_user_session_path, method: :delete, class: "w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2h5a2 2 0 012 2v1" />
            </svg>
            Log out
          <% end %>
        </div>
      </aside>

      <%# Main content %>
      <main class="flex-1 ml-64">
        <div class="px-8 py-6">
          <% if notice.present? %>
            <div class="mb-4 rounded-md bg-green-50 p-4">
              <p class="text-sm text-green-700"><%= notice %></p>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="mb-4 rounded-md bg-red-50 p-4">
              <p class="text-sm text-red-700"><%= alert %></p>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
