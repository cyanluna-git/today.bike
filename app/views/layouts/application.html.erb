<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Today Bike" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Today Bike">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= render "shared/meta_tags" %>

    <%= yield :head %>

    <%# JSON-LD structured data %>
    <%= yield :json_ld %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 flex flex-col">
    <% if devise_controller? %>
      <main class="flex flex-1 items-center justify-center px-4">
        <%= yield %>
      </main>
    <% else %>
      <main class="container mx-auto mt-8 px-4 sm:px-6 pb-28 flex flex-1">
        <%= yield %>
      </main>

      <%# Floating Pill Navigation %>
      <%
        active_page = case
          when request.path == "/" then "home"
          when request.path.start_with?("/services") then "services"
          when request.path.start_with?("/blog") then "blog"
          when request.path.start_with?("/products") then "products"
          when request.path.start_with?("/rentals") then "rentals"
          when request.path == "/gallery" then "gallery"
          else ""
        end
      %>
      <div data-controller="pill-nav"
           data-pill-nav-active-page-value="<%= active_page %>"
           data-pill-nav-active-class="!text-indigo-600 !font-semibold"
           class="fixed bottom-5 left-1/2 -translate-x-1/2 z-50">

        <%# Submenu overlay %>
        <div data-pill-nav-target="submenuOverlay"
             data-action="click->pill-nav#close"
             class="hidden fixed inset-0 z-40"></div>

        <%# Service submenu popover %>
        <div data-pill-nav-target="submenu"
             aria-hidden="true"
             class="hidden absolute bottom-full left-1/2 -translate-x-1/2 mb-3 z-50">
          <div class="backdrop-blur-lg bg-white/80 border border-white/30 shadow-xl rounded-2xl p-3 grid grid-cols-2 gap-2 min-w-[280px]">
            <%= link_to service_page_path("overhaul"), class: "flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-indigo-50 transition group" do %>
              <div class="w-9 h-9 bg-indigo-100 rounded-lg flex items-center justify-center group-hover:bg-indigo-200 transition">
                <svg class="w-4.5 h-4.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-900">분해정비</div>
                <div class="text-xs text-gray-500">완전 분해 세척</div>
              </div>
            <% end %>
            <%= link_to service_page_path("repair"), class: "flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-green-50 transition group" do %>
              <div class="w-9 h-9 bg-green-100 rounded-lg flex items-center justify-center group-hover:bg-green-200 transition">
                <svg class="w-4.5 h-4.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-900">수리</div>
                <div class="text-xs text-gray-500">고장 진단 처치</div>
              </div>
            <% end %>
            <%= link_to service_page_path("fitting"), class: "flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-amber-50 transition group" do %>
              <div class="w-9 h-9 bg-amber-100 rounded-lg flex items-center justify-center group-hover:bg-amber-200 transition">
                <svg class="w-4.5 h-4.5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-900">피팅</div>
                <div class="text-xs text-gray-500">체형 맞춤 세팅</div>
              </div>
            <% end %>
            <%= link_to service_page_path("upgrade"), class: "flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-rose-50 transition group" do %>
              <div class="w-9 h-9 bg-rose-100 rounded-lg flex items-center justify-center group-hover:bg-rose-200 transition">
                <svg class="w-4.5 h-4.5 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-gray-900">업그레이드</div>
                <div class="text-xs text-gray-500">부품 교체 업그레이드</div>
              </div>
            <% end %>
          </div>
        </div>

        <%# Pill bar %>
        <nav class="flex items-center gap-1 overflow-x-auto whitespace-nowrap rounded-full border border-gray-200 bg-white/90 px-3 py-2 shadow-2xl backdrop-blur-xl"
             role="navigation" aria-label="메인 네비게이션">
          <%# Logo / Home %>
          <%= link_to root_path, data: { pill_nav_target: "pill", page: "home" },
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white/60 hover:text-indigo-600 whitespace-nowrap" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="7" cy="17" r="3" stroke-width="2"/>
              <circle cx="17" cy="17" r="3" stroke-width="2"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17L14 7h-4l3 10M7 17l3-10"/>
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">홈</span>
          <% end %>

          <span class="w-px h-5 bg-gray-300/50"></span>

          <%# Services (with submenu toggle) %>
          <button type="button"
                  data-pill-nav-target="pill" data-page="services"
                  data-action="click->pill-nav#toggle"
                  aria-expanded="false"
                  aria-controls="services-submenu"
                  class="flex shrink-0 items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white/60 hover:text-indigo-600 whitespace-nowrap">
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">서비스</span>
            <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
            </svg>
          </button>

          <%# Blog %>
          <%= link_to blog_path, data: { pill_nav_target: "pill", page: "blog" },
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white/60 hover:text-indigo-600 whitespace-nowrap" do %>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">블로그</span>
          <% end %>

          <%# Products %>
          <%= link_to products_path, data: { pill_nav_target: "pill", page: "products" },
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white/60 hover:text-indigo-600 whitespace-nowrap" do %>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">파츠</span>
          <% end %>

          <%# Rentals %>
          <%= link_to rentals_path, data: { pill_nav_target: "pill", page: "rentals" },
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white/60 hover:text-indigo-600 whitespace-nowrap" do %>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">대여</span>
          <% end %>

          <%# Gallery %>
          <%= link_to gallery_path, data: { pill_nav_target: "pill", page: "gallery" },
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-white/60 hover:text-indigo-600 whitespace-nowrap" do %>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">갤러리</span>
          <% end %>

          <span class="w-px h-5 bg-gray-300/50"></span>

          <%# Portal %>
          <%= link_to portal_login_path,
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-2.5 py-2 text-xs font-medium text-gray-400 transition hover:bg-white/60 hover:text-blue-600 whitespace-nowrap" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">내 정비</span>
          <% end %>

          <%# Admin %>
          <%= link_to admin_root_path,
                class: "flex shrink-0 items-center gap-1.5 rounded-full px-2.5 py-2 text-xs font-medium text-gray-400 transition hover:bg-white/60 hover:text-gray-600 whitespace-nowrap" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <span class="hidden whitespace-nowrap sm:inline">관리자</span>
          <% end %>
        </nav>
      </div>

      <%# Footer %>
      <footer class="bg-white border-t border-gray-200">
        <div class="container mx-auto px-4 sm:px-6 py-8 pb-24">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-gray-500">&copy; <%= Date.current.year %> Today.bike. All rights reserved.</p>
            <nav class="flex gap-4 text-sm text-gray-500">
              <%= link_to "서비스", service_page_path("overhaul"), class: "hover:text-gray-700 transition" %>
              <%= link_to "블로그", blog_path, class: "hover:text-gray-700 transition" %>
              <%= link_to "파츠", products_path, class: "hover:text-gray-700 transition" %>
              <%= link_to "대여", rentals_path, class: "hover:text-gray-700 transition" %>
              <%= link_to "갤러리", gallery_path, class: "hover:text-gray-700 transition" %>
              <span class="text-gray-300">|</span>
              <%= link_to "내 정비이력", portal_login_path, class: "hover:text-gray-700 transition" %>
              <%= link_to "관리자", admin_root_path, class: "hover:text-gray-700 transition" %>
            </nav>
          </div>
        </div>
      </footer>
    <% end %>
  </body>
</html>
