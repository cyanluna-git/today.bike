<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Today Bike" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Today Bike">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= render "shared/meta_tags" %>

    <%= yield :head %>

    <%# JSON-LD structured data %>
    <%= yield :json_ld %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 flex flex-col" data-controller="mobile-nav">
    <%# Mobile overlay %>
    <div data-mobile-nav-target="overlay"
         data-action="click->mobile-nav#close"
         class="hidden fixed inset-0 bg-gray-900/50 z-40"></div>

    <%# Public navigation header %>
    <header class="bg-white shadow-sm sticky top-0 z-30">
      <nav class="container mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <%# Logo %>
          <%= link_to root_path, class: "flex items-center gap-2 shrink-0" do %>
            <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="7" cy="17" r="3" stroke-width="2"/>
              <circle cx="17" cy="17" r="3" stroke-width="2"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17L14 7h-4l3 10M7 17l3-10"/>
            </svg>
            <span class="text-lg font-bold text-gray-900">Today.bike</span>
          <% end %>

          <%# Desktop nav links %>
          <div class="hidden md:flex items-center gap-6">
            <%= link_to "서비스", service_page_path("overhaul"), class: "text-sm font-medium #{request.path.start_with?('/services') ? 'text-indigo-600' : 'text-gray-700 hover:text-indigo-600'} transition" %>
            <%= link_to "블로그", blog_path, class: "text-sm font-medium #{request.path.start_with?('/blog') ? 'text-indigo-600' : 'text-gray-700 hover:text-indigo-600'} transition" %>
            <%= link_to "파츠", products_path, class: "text-sm font-medium #{request.path.start_with?('/products') ? 'text-indigo-600' : 'text-gray-700 hover:text-indigo-600'} transition" %>
            <%= link_to "대여", rentals_path, class: "text-sm font-medium #{request.path.start_with?('/rentals') ? 'text-indigo-600' : 'text-gray-700 hover:text-indigo-600'} transition" %>
            <%= link_to "갤러리", gallery_path, class: "text-sm font-medium #{request.path == '/gallery' ? 'text-indigo-600' : 'text-gray-700 hover:text-indigo-600'} transition" %>
          </div>

          <%# Mobile hamburger button %>
          <button type="button" data-action="click->mobile-nav#toggle"
                  class="md:hidden p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition"
                  aria-label="Toggle navigation menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>

      <%# Mobile nav menu %>
      <div data-mobile-nav-target="menu" class="hidden md:hidden fixed inset-y-0 right-0 w-64 bg-white shadow-xl z-50">
        <div class="flex items-center justify-between px-4 h-16 border-b border-gray-100">
          <span class="text-lg font-bold text-gray-900">Today.bike</span>
          <button type="button" data-action="click->mobile-nav#close"
                  class="p-2 rounded-md text-gray-400 hover:text-gray-600 transition"
                  aria-label="Close navigation menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="px-4 py-4 space-y-1">
          <%= link_to "홈", root_path, class: "block px-3 py-2.5 text-base font-medium rounded-lg #{request.path == '/' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-50'} transition" %>
          <%= link_to "서비스", service_page_path("overhaul"), class: "block px-3 py-2.5 text-base font-medium rounded-lg #{request.path.start_with?('/services') ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-50'} transition" %>
          <%= link_to "블로그", blog_path, class: "block px-3 py-2.5 text-base font-medium rounded-lg #{request.path.start_with?('/blog') ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-50'} transition" %>
          <%= link_to "파츠", products_path, class: "block px-3 py-2.5 text-base font-medium rounded-lg #{request.path.start_with?('/products') ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-50'} transition" %>
          <%= link_to "대여", rentals_path, class: "block px-3 py-2.5 text-base font-medium rounded-lg #{request.path.start_with?('/rentals') ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-50'} transition" %>
          <%= link_to "갤러리", gallery_path, class: "block px-3 py-2.5 text-base font-medium rounded-lg #{request.path == '/gallery' ? 'bg-indigo-50 text-indigo-600' : 'text-gray-700 hover:bg-gray-50'} transition" %>
        </nav>
      </div>
    </header>

    <main class="container mx-auto mt-8 px-4 sm:px-6 pb-16 flex flex-1">
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="bg-white border-t border-gray-200">
      <div class="container mx-auto px-4 sm:px-6 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-gray-500">&copy; <%= Date.current.year %> Today.bike. All rights reserved.</p>
          <nav class="flex gap-4 text-sm text-gray-500">
            <%= link_to "서비스", service_page_path("overhaul"), class: "hover:text-gray-700 transition" %>
            <%= link_to "블로그", blog_path, class: "hover:text-gray-700 transition" %>
            <%= link_to "파츠", products_path, class: "hover:text-gray-700 transition" %>
            <%= link_to "대여", rentals_path, class: "hover:text-gray-700 transition" %>
            <%= link_to "갤러리", gallery_path, class: "hover:text-gray-700 transition" %>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>
