<% content_for(:title, "#{@product.name} - Products - Today Bike") %>

<% content_for(:meta_tags) do %>
  <meta name="description" content="<%= @product.description.to_s.truncate(160) %>">
  <meta property="og:title" content="<%= @product.name %> - Today.bike">
  <meta property="og:description" content="<%= @product.description.to_s.truncate(160) %>">
  <meta property="og:type" content="product">
<% end %>

<% content_for(:json_ld) do %>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "<%= j @product.name %>",
      "description": "<%= j @product.description.to_s.truncate(300) %>",
      "brand": {
        "@type": "Brand",
        "name": "<%= j @product.brand.to_s %>"
      },
      "offers": {
        "@type": "Offer",
        "price": "<%= @product.display_price %>",
        "priceCurrency": "KRW",
        "availability": "<%= @product.stock_quantity > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>",
        "url": "<%= product_url(@product) %>"
      },
      "sku": "<%= j @product.sku.to_s %>"
    }
  </script>
<% end %>

<div class="w-full max-w-6xl mx-auto">
  <div class="mb-6">
    <%= link_to products_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Products
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <%# Image Gallery %>
    <div>
      <% if @product.images.attached? %>
        <div class="space-y-4" data-controller="image-gallery">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <%= image_tag @product.images.first.variant(resize_to_limit: [800, 600]),
                  class: "w-full object-contain max-h-96",
                  data: { image_gallery_target: "main" } %>
          </div>
          <% if @product.images.count > 1 %>
            <div class="grid grid-cols-4 gap-2">
              <% @product.images.each_with_index do |image, index| %>
                <button type="button" class="bg-white shadow rounded overflow-hidden hover:ring-2 hover:ring-indigo-500 transition"
                        data-action="click->image-gallery#select"
                        data-image-gallery-url-param="<%= url_for(image.variant(resize_to_limit: [800, 600])) %>">
                  <%= image_tag image.variant(resize_to_limit: [200, 200]), class: "w-full h-20 object-cover" %>
                </button>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gradient-to-br from-indigo-100 to-indigo-50 rounded-lg flex items-center justify-center h-96">
          <svg class="w-24 h-24 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
      <% end %>
    </div>

    <%# Product Details %>
    <div>
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= @product.category_label %></span>
        <% if @product.brand.present? %>
          <span class="text-sm text-gray-500"><%= @product.brand %></span>
        <% end %>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @product.name %></h1>

      <div class="mb-6">
        <% if @product.on_sale? %>
          <div class="flex items-center gap-3">
            <span class="line-through text-gray-400 text-xl"><%= number_to_currency(@product.price, unit: "₩", precision: 0) %></span>
            <span class="text-red-600 font-bold text-3xl"><%= number_to_currency(@product.sale_price, unit: "₩", precision: 0) %></span>
          </div>
        <% else %>
          <span class="font-bold text-3xl text-gray-900"><%= number_to_currency(@product.price, unit: "₩", precision: 0) %></span>
        <% end %>
      </div>

      <% if @product.stock_quantity > 0 %>
        <p class="text-sm text-green-700 mb-4">In stock</p>
      <% else %>
        <p class="text-sm text-red-600 mb-4">Out of stock</p>
      <% end %>

      <% if @product.description.present? %>
        <div class="prose max-w-none text-gray-700 mb-6">
          <%= simple_format(@product.description) %>
        </div>
      <% end %>

      <% if @product.sku.present? %>
        <p class="text-xs text-gray-400 mb-6">SKU: <%= @product.sku %></p>
      <% end %>

      <%# Kakao inquiry button %>
      <div class="mt-8">
        <%= link_to "https://pf.kakao.com/_todaybike/chat", target: "_blank", rel: "noopener noreferrer",
              class: "inline-flex items-center gap-2 rounded-md bg-yellow-400 px-6 py-3 text-sm font-semibold text-gray-900 shadow-sm hover:bg-yellow-300 transition" do %>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.47 1.607 4.647 4.042 5.906-.178.663-.647 2.41-.741 2.785-.118.47.173.464.364.337.15-.1 2.38-1.619 3.34-2.275.32.042.65.064.985.064 5.523 0 10-3.477 10-7.817C20 6.477 17.523 3 12 3z"/>
          </svg>
          카카오톡 문의하기
        <% end %>
      </div>
    </div>
  </div>
</div>
