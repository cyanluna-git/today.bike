<% content_for(:title) { "#{@service_order.order_number} - Today Bike" } %>

<%
  status_colors = {
    "received" => "bg-blue-100 text-blue-800",
    "diagnosis" => "bg-yellow-100 text-yellow-800",
    "in_progress" => "bg-orange-100 text-orange-800",
    "completed" => "bg-green-100 text-green-800",
    "delivered" => "bg-gray-100 text-gray-600"
  }
  status_labels = {
    "received" => "접수",
    "diagnosis" => "진단",
    "in_progress" => "작업중",
    "completed" => "완료",
    "delivered" => "출고"
  }
  service_type_labels = {
    "overhaul" => "오버홀",
    "repair" => "수리",
    "parts" => "부품교체",
    "upgrade" => "업그레이드",
    "fitting" => "피팅",
    "frame_change" => "기변"
  }
%>

<div class="mb-4">
  <%= link_to portal_service_orders_path, class: "text-sm text-blue-600 hover:text-blue-800" do %>
    &larr; 정비이력 목록
  <% end %>
</div>

<%= turbo_stream_from @service_order %>

<div id="<%= dom_id(@service_order) %>">
  <%= render "service_order_detail", service_order: @service_order %>
</div>
