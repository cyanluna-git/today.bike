<%
  status_colors = {
    "received" => "bg-blue-100 text-blue-800",
    "diagnosis" => "bg-yellow-100 text-yellow-800",
    "in_progress" => "bg-orange-100 text-orange-800",
    "completed" => "bg-green-100 text-green-800",
    "delivered" => "bg-gray-100 text-gray-600"
  }
  status_labels = {
    "received" => "접수",
    "diagnosis" => "진단",
    "in_progress" => "작업중",
    "completed" => "완료",
    "delivered" => "출고"
  }
  service_type_labels = {
    "overhaul" => "오버홀",
    "repair" => "수리",
    "parts" => "부품교체",
    "upgrade" => "업그레이드",
    "fitting" => "피팅",
    "frame_change" => "기변"
  }
%>

<%# Order header %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4">
  <div class="flex items-start justify-between mb-3">
    <div>
      <h1 class="text-lg font-bold text-gray-900" data-testid="order-number"><%= service_order.order_number %></h1>
      <span class="inline-block mt-1 text-xs font-medium px-2 py-0.5 rounded-full <%= status_colors[service_order.status] %>" data-testid="status-badge">
        <%= status_labels[service_order.status] %>
      </span>
    </div>
    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-purple-50 text-purple-700" data-testid="service-type-label">
      <%= service_type_labels[service_order.service_type] %>
    </span>
  </div>

  <%# Bicycle info %>
  <div class="text-sm text-gray-600 mb-3">
    <p class="font-medium text-gray-900"><%= service_order.bicycle.brand %> <%= service_order.bicycle.model_label %></p>
  </div>

  <%# Dates %>
  <dl class="grid grid-cols-2 gap-2 text-sm">
    <div>
      <dt class="text-gray-400">접수일</dt>
      <dd class="text-gray-900"><%= service_order.received_at&.strftime("%Y.%m.%d") %></dd>
    </div>
    <% if service_order.expected_completion.present? %>
      <div>
        <dt class="text-gray-400">예상완료일</dt>
        <dd class="text-gray-900"><%= service_order.expected_completion&.strftime("%Y.%m.%d") %></dd>
      </div>
    <% end %>
    <% if service_order.completed_at.present? %>
      <div>
        <dt class="text-gray-400">완료일</dt>
        <dd class="text-gray-900"><%= service_order.completed_at&.strftime("%Y.%m.%d") %></dd>
      </div>
    <% end %>
    <% if service_order.delivered_at.present? %>
      <div>
        <dt class="text-gray-400">출고일</dt>
        <dd class="text-gray-900"><%= service_order.delivered_at&.strftime("%Y.%m.%d") %></dd>
      </div>
    <% end %>
  </dl>

  <%# Cost %>
  <% if service_order.estimated_cost.present? || service_order.final_cost.present? %>
    <div class="mt-3 pt-3 border-t border-gray-100">
      <dl class="grid grid-cols-2 gap-2 text-sm">
        <% if service_order.estimated_cost.present? %>
          <div>
            <dt class="text-gray-400">예상비용</dt>
            <dd class="text-gray-900 font-medium"><%= number_with_delimiter(service_order.estimated_cost.to_i) %>원</dd>
          </div>
        <% end %>
        <% if service_order.final_cost.present? %>
          <div>
            <dt class="text-gray-400">최종비용</dt>
            <dd class="text-gray-900 font-bold"><%= number_with_delimiter(service_order.final_cost.to_i) %>원</dd>
          </div>
        <% end %>
      </dl>
    </div>
  <% end %>
</div>

<%# Progress timeline %>
<% progresses = service_order.service_progresses.chronological %>
<% if progresses.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4" data-testid="progress-timeline">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">진행 현황</h2>
    <ol class="relative border-l-2 border-gray-200 ml-2 space-y-4">
      <% progresses.each do |progress| %>
        <li class="ml-4">
          <div class="absolute -left-[7px] mt-1.5 w-3 h-3 rounded-full border-2 border-white <%= progress == progresses.last ? 'bg-blue-600' : 'bg-gray-300' %>"></div>
          <div>
            <p class="text-sm font-medium text-gray-900">
              <%= ServiceProgress::STATUS_LABELS[progress.to_status] || progress.to_status %>
            </p>
            <p class="text-xs text-gray-400"><%= progress.changed_at&.strftime("%Y.%m.%d %H:%M") %></p>
            <% if progress.note.present? %>
              <p class="text-xs text-gray-500 mt-0.5"><%= progress.note %></p>
            <% end %>
          </div>
        </li>
      <% end %>
    </ol>
  </div>
<% end %>

<%# Service photos %>
<% photos = service_order.service_photos.ordered %>
<% if photos.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4" data-testid="service-photos">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">정비 사진</h2>
    <div class="grid grid-cols-2 gap-2">
      <% photos.each do |photo| %>
        <% if photo.image.attached? %>
          <div class="relative rounded-lg overflow-hidden bg-gray-100 aspect-square">
            <%= image_tag photo.thumbnail, class: "w-full h-full object-cover" %>
            <span class="absolute bottom-1 left-1 text-xs font-medium px-1.5 py-0.5 rounded bg-black/50 text-white">
              <%= photo.type_label %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Repair logs (read-only, no internal notes) %>
<% repair_logs = service_order.repair_logs.ordered %>
<% if repair_logs.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4" data-testid="repair-logs">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">수리 내역</h2>
    <div class="space-y-3">
      <% repair_logs.each do |log| %>
        <div class="border-b border-gray-50 last:border-0 pb-3 last:pb-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-700"><%= log.category_label %></span>
          </div>
          <p class="text-sm text-gray-900"><%= log.symptom %></p>
          <% if log.treatment.present? %>
            <p class="text-xs text-gray-500 mt-1">처리: <%= log.treatment %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Parts replacements (read-only) %>
<% parts = service_order.parts_replacements.ordered %>
<% if parts.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4" data-testid="parts-replacements">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">부품 교체</h2>
    <div class="space-y-3">
      <% parts.each do |part| %>
        <div class="border-b border-gray-50 last:border-0 pb-3 last:pb-0">
          <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-700"><%= part.component_label %></span>
          <div class="mt-1 text-sm">
            <% if part.old_brand.present? %>
              <p class="text-gray-400 line-through text-xs"><%= part.old_brand %> <%= part.old_model %></p>
            <% end %>
            <p class="text-gray-900 font-medium"><%= part.new_brand %> <%= part.new_model %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
