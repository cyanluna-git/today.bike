<%
  content_for(:title) { "포털 홈 - Today Bike" }

  status_colors = {
    "received" => "bg-blue-100 text-blue-800",
    "diagnosis" => "bg-yellow-100 text-yellow-800",
    "in_progress" => "bg-orange-100 text-orange-800",
    "completed" => "bg-green-100 text-green-800",
    "delivered" => "bg-gray-100 text-gray-600"
  }
  status_labels = {
    "received" => "접수",
    "diagnosis" => "진단",
    "in_progress" => "작업중",
    "completed" => "완료",
    "delivered" => "출고"
  }
  service_type_labels = {
    "overhaul" => "오버홀",
    "repair" => "수리",
    "parts" => "부품교체",
    "upgrade" => "업그레이드",
    "fitting" => "피팅",
    "frame_change" => "기변"
  }
  latest_active_order = @active_service_orders.max_by do |service_order|
    service_order.service_progresses.max_by(&:changed_at)&.changed_at || service_order.received_at || service_order.created_at
  end
%>

<section class="mb-8 rounded-3xl bg-gradient-to-br from-gray-900 via-slate-800 to-slate-700 px-6 py-7 text-white shadow-sm sm:px-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm font-medium text-slate-200">고객 포털</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl"><%= current_customer.name %>님, 자전거 현황을 확인하세요.</h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-200 sm:text-base">
        진행 중인 정비, 최근 업데이트, 보유 자전거 상태를 한곳에서 보고 필요한 상세 화면으로 바로 이동할 수 있습니다.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "정비 이력 보기", portal_service_orders_path,
            class: "inline-flex items-center justify-center rounded-full bg-white px-4 py-2 text-sm font-semibold text-slate-900 transition hover:bg-slate-100" %>
      <%= link_to "피팅 기록 보기", portal_fitting_records_path,
            class: "inline-flex items-center justify-center rounded-full border border-white/30 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10" %>
    </div>
  </div>
</section>

<section class="mb-8 grid gap-4 md:grid-cols-3">
  <article class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm" data-testid="summary-card-active-work">
    <p class="text-sm font-medium text-gray-500">진행 중 작업</p>
    <p class="mt-3 text-2xl font-bold text-gray-900"><%= @active_service_orders.count %>건</p>
    <% if latest_active_order.present? %>
      <p class="mt-2 text-sm text-gray-600">
        최근 작업: <span class="font-medium text-gray-900"><%= latest_active_order.bicycle.brand %> <%= latest_active_order.bicycle.model_label %></span>
      </p>
      <p class="mt-1 text-xs text-gray-500">
        현재 단계 <%= status_labels[latest_active_order.status] %>
      </p>
    <% else %>
      <p class="mt-2 text-sm text-gray-600">현재 진행 중인 정비가 없습니다.</p>
      <p class="mt-1 text-xs text-gray-500">필요할 때 정비 이력에서 이전 작업을 다시 확인할 수 있습니다.</p>
    <% end %>
  </article>

  <article class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm" data-testid="summary-card-recent-update">
    <p class="text-sm font-medium text-gray-500">최근 업데이트</p>
    <% if @recent_update_at.present? %>
      <p class="mt-3 text-2xl font-bold text-gray-900"><%= portal_month_day(@recent_update_at) %></p>
      <p class="mt-2 text-sm text-gray-600"><%= portal_datetime(@recent_update_at) %> 기준 최근 변경이 반영되었습니다.</p>
    <% else %>
      <p class="mt-3 text-2xl font-bold text-gray-900">-</p>
      <p class="mt-2 text-sm text-gray-600">아직 표시할 정비 또는 피팅 업데이트가 없습니다.</p>
    <% end %>
  </article>

  <article class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm" data-testid="summary-card-bicycle-count">
    <p class="text-sm font-medium text-gray-500">보유 자전거</p>
    <p class="mt-3 text-2xl font-bold text-gray-900"><%= @bicycles.count %>대</p>
    <p class="mt-2 text-sm text-gray-600">
      <% if @bicycles.any? %>
        최근 등록 자전거 <span class="font-medium text-gray-900"><%= @bicycles.first.brand %> <%= @bicycles.first.model_label %></span>
      <% else %>
        아직 등록된 자전거가 없습니다.
      <% end %>
    </p>
  </article>
</section>

<section class="mb-8 rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-bold text-gray-900">진행 중인 작업</h2>
      <p class="text-sm text-gray-500">현재 진행 상황과 최근 변경 여부를 빠르게 확인하세요.</p>
    </div>
    <%= link_to "전체 정비 이력", portal_service_orders_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
  </div>

  <% if @active_service_orders.any? %>
    <div class="space-y-3">
      <% @active_service_orders.each do |service_order| %>
        <% last_update_at = service_order.service_progresses.max_by(&:changed_at)&.changed_at || service_order.received_at || service_order.created_at %>
        <%= link_to portal_service_order_path(service_order), class: "block rounded-2xl border border-gray-100 bg-gray-50 p-4 transition hover:border-blue-200 hover:bg-white", data: { testid: "active-service-order-card" } do %>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <p class="text-sm font-semibold text-gray-900"><%= service_order.bicycle.brand %> <%= service_order.bicycle.model_label %></p>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= status_colors[service_order.status] %>">
                  <%= status_labels[service_order.status] %>
                </span>
              </div>
              <p class="mt-1 text-sm text-gray-600">
                <%= service_type_labels[service_order.service_type] %> · 주문번호 <%= service_order.order_number %>
              </p>
            </div>
            <div class="text-sm text-gray-500 sm:text-right">
              <p>최근 반영 <%= portal_datetime(last_update_at) %></p>
              <p class="mt-1 text-xs">상세 화면에서 전체 진행 내역을 볼 수 있습니다.</p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-gray-200 bg-gray-50 px-4 py-8 text-center">
      <p class="text-sm font-medium text-gray-700">현재 진행 중인 정비가 없습니다.</p>
      <p class="mt-2 text-sm text-gray-500">이전 정비 이력과 완료된 작업 내역은 정비 이력 화면에서 다시 볼 수 있습니다.</p>
    </div>
  <% end %>
</section>

<section class="mb-8">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-bold text-gray-900">내 자전거 요약</h2>
      <p class="text-sm text-gray-500">자전거별 현재 상태와 최근 정비/피팅 이력을 함께 확인하세요.</p>
    </div>
  </div>

  <% if @bicycle_summaries.any? %>
    <div class="grid gap-4 lg:grid-cols-2">
      <% @bicycle_summaries.each do |summary| %>
        <% bicycle = summary[:bicycle] %>
        <% active_order = summary[:active_order] %>
        <% latest_service_order = summary[:latest_service_order] %>
        <% latest_fitting_record = summary[:latest_fitting_record] %>
        <%= link_to portal_bicycle_path(bicycle), class: "block rounded-3xl border border-gray-100 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md", data: { testid: "bicycle-card" } do %>
          <div class="flex flex-col gap-4 sm:flex-row">
            <% if bicycle.photos.attached? %>
              <div class="h-40 w-full overflow-hidden rounded-2xl bg-gray-100 sm:h-28 sm:w-28 sm:shrink-0">
                <%= image_tag bicycle.photo_thumbnail(bicycle.photos.first), class: "h-full w-full object-cover" %>
              </div>
            <% end %>

            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <span class="inline-flex rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700"><%= bicycle.bike_type.upcase %></span>
                <% if active_order.present? %>
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= status_colors[active_order.status] %>">
                    <%= status_labels[active_order.status] %>
                  </span>
                <% elsif bicycle.status != "active" %>
                  <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">
                    <%= bicycle.status == "sold" ? "판매됨" : "폐차" %>
                  </span>
                <% end %>
              </div>

              <h3 class="mt-3 text-lg font-semibold text-gray-900"><%= bicycle.brand %></h3>
              <p class="text-sm text-gray-600"><%= bicycle.model_label %></p>

              <dl class="mt-4 grid gap-3 text-sm md:grid-cols-2">
                <div>
                  <dt class="text-gray-400 break-keep">최근 정비</dt>
                  <dd class="mt-1 font-medium text-gray-900 break-keep">
                    <% if latest_service_order.present? %>
                      <%= service_type_labels[latest_service_order.service_type] %>
                      <span class="mt-1 block text-xs font-normal text-gray-500 break-keep">
                        <%= portal_date(latest_service_order.completed_at || latest_service_order.received_at || latest_service_order.created_at) %>
                      </span>
                    <% else %>
                      -
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-gray-400 break-keep">최근 피팅</dt>
                  <dd class="mt-1 font-medium text-gray-900 break-keep">
                    <% if latest_fitting_record.present? %>
                      <%= portal_date(latest_fitting_record.recorded_at) %>
                      <span class="mt-1 block text-xs font-normal text-gray-500 break-keep">최근 세팅 기록 확인</span>
                    <% else %>
                      -
                    <% end %>
                  </dd>
                </div>
              </dl>

              <div class="mt-4 w-full">
                <%= render "lifecycle_reminder", reminder: summary[:lifecycle_reminder], compact: true %>
              </div>

              <p class="mt-4 text-xs font-medium text-blue-700">상세 보기</p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-3xl border border-dashed border-gray-200 bg-white px-4 py-10 text-center">
      <p class="text-sm font-medium text-gray-700">등록된 자전거가 아직 없습니다.</p>
      <p class="mt-2 text-sm text-gray-500">자전거가 등록되면 정비와 피팅 이력을 이곳에서 한눈에 확인할 수 있습니다.</p>
    </div>
  <% end %>
</section>

<section class="mb-8 grid gap-4 xl:grid-cols-2">
  <article class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-bold text-gray-900">최근 정비 요약</h2>
        <p class="text-sm text-gray-500">최근 완료 또는 접수된 작업 흐름을 다시 확인하세요.</p>
      </div>
      <%= link_to "정비 이력 전체", portal_service_orders_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
    </div>

    <% if @recent_service_orders.any? %>
      <div class="space-y-3">
        <% @recent_service_orders.each do |service_order| %>
          <%= link_to portal_service_order_path(service_order), class: "flex items-start justify-between gap-4 rounded-2xl bg-gray-50 px-4 py-3 transition hover:bg-gray-100", data: { testid: "recent-service-order" } do %>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900"><%= service_order.bicycle.brand %> <%= service_order.bicycle.model_label %></p>
              <p class="mt-1 text-sm text-gray-600"><%= service_type_labels[service_order.service_type] %> · <%= service_order.order_number %></p>
            </div>
            <div class="text-right">
              <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= status_colors[service_order.status] %>"><%= status_labels[service_order.status] %></span>
              <p class="mt-2 text-xs text-gray-500"><%= portal_date(service_order.completed_at || service_order.received_at || service_order.created_at) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="rounded-2xl bg-gray-50 px-4 py-6 text-sm text-gray-500">표시할 정비 이력이 없습니다.</p>
    <% end %>
  </article>

  <article class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-bold text-gray-900">최근 피팅 요약</h2>
        <p class="text-sm text-gray-500">최근 조정 기록과 세팅 변화를 다시 볼 수 있습니다.</p>
      </div>
      <%= link_to "피팅 기록 전체", portal_fitting_records_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
    </div>

    <% if @recent_fitting_records.any? %>
      <div class="space-y-3">
        <% @recent_fitting_records.each do |fitting_record| %>
          <%= link_to portal_fitting_record_path(fitting_record), class: "flex items-start justify-between gap-4 rounded-2xl bg-gray-50 px-4 py-3 transition hover:bg-gray-100", data: { testid: "recent-fitting-record" } do %>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900"><%= fitting_record.bicycle.brand %> <%= fitting_record.bicycle.model_label %></p>
              <p class="mt-1 text-sm text-gray-600"><%= fitting_record.notes.presence || "최근 피팅 기록 확인" %></p>
            </div>
            <p class="shrink-0 text-xs text-gray-500"><%= portal_date(fitting_record.recorded_at) %></p>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="rounded-2xl bg-gray-50 px-4 py-6 text-sm text-gray-500">표시할 피팅 기록이 없습니다.</p>
    <% end %>
  </article>
</section>

<section class="mb-8 rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-bold text-gray-900">최근 업데이트</h2>
      <p class="text-sm text-gray-500">정비 진행 소식과 일반 안내를 한곳에서 확인하세요.</p>
    </div>
    <%= link_to "전체 업데이트", portal_updates_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
  </div>

  <% if @recent_updates.any? %>
    <div class="space-y-3">
      <% @recent_updates.each do |update| %>
        <%= render "portal/updates/update_item", update: update, compact: true %>
      <% end %>
    </div>
  <% else %>
    <p class="rounded-2xl bg-gray-50 px-4 py-6 text-sm text-gray-500">표시할 업데이트가 없습니다.</p>
  <% end %>
</section>

<section class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm" data-testid="portal-next-actions">
  <div class="mb-4">
    <h2 class="text-lg font-bold text-gray-900">다음에 할 수 있는 일</h2>
    <p class="text-sm text-gray-500">필요한 상세 화면으로 바로 이동해 현재 상태를 더 자세히 확인하세요.</p>
  </div>

  <div class="grid gap-3 md:grid-cols-3">
    <%= link_to (@active_service_orders.any? ? portal_service_order_path(@active_service_orders.first) : portal_service_orders_path),
          class: "rounded-2xl border border-gray-100 bg-gray-50 px-4 py-4 transition hover:border-blue-200 hover:bg-white" do %>
      <p class="text-sm font-semibold text-gray-900"><%= @active_service_orders.any? ? "진행 중 작업 상세 보기" : "정비 이력 확인하기" %></p>
      <p class="mt-1 text-sm text-gray-500">정비 단계와 최근 업데이트를 확인합니다.</p>
    <% end %>

    <%= link_to (@recent_fitting_records.any? ? portal_fitting_record_path(@recent_fitting_records.first) : portal_fitting_records_path),
          class: "rounded-2xl border border-gray-100 bg-gray-50 px-4 py-4 transition hover:border-blue-200 hover:bg-white" do %>
      <p class="text-sm font-semibold text-gray-900"><%= @recent_fitting_records.any? ? "최근 피팅 기록 보기" : "피팅 기록 확인하기" %></p>
      <p class="mt-1 text-sm text-gray-500">최근 세팅값과 피팅 메모를 다시 봅니다.</p>
    <% end %>

    <%= link_to (@bicycle_summaries.any? ? portal_bicycle_path(@bicycle_summaries.first[:bicycle]) : portal_bicycles_path),
          class: "rounded-2xl border border-gray-100 bg-gray-50 px-4 py-4 transition hover:border-blue-200 hover:bg-white" do %>
      <p class="text-sm font-semibold text-gray-900"><%= @bicycle_summaries.any? ? "내 자전거 상세 보기" : "내 자전거 확인하기" %></p>
      <p class="mt-1 text-sm text-gray-500">자전거 사양과 개별 이력을 더 자세히 확인합니다.</p>
    <% end %>
  </div>
</section>
