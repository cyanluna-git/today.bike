<% content_for(:title) { "#{@bicycle.brand} #{@bicycle.model_label} - Today Bike" } %>

<div class="mb-4">
  <%= link_to portal_bicycles_path, class: "text-sm text-blue-600 hover:text-blue-800" do %>
    &larr; 내 자전거 목록
  <% end %>
</div>

<%# Bicycle header %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
  <% if @bicycle.photos.attached? %>
    <div class="h-48 bg-gray-100 overflow-hidden">
      <%= image_tag @bicycle.photo_thumbnail(@bicycle.photos.first), class: "w-full h-full object-cover" %>
    </div>
  <% end %>

  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-blue-50 text-blue-700"><%= @bicycle.bike_type.upcase %></span>
      <% if @bicycle.status != "active" %>
        <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= @bicycle.status == "sold" ? "판매됨" : "폐차" %></span>
      <% end %>
    </div>
    <h1 class="text-xl font-bold text-gray-900"><%= @bicycle.brand %></h1>
    <p class="text-gray-600"><%= @bicycle.model_label %></p>

    <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
      <% if @bicycle.year.present? %>
        <div>
          <dt class="text-gray-400">연식</dt>
          <dd class="font-medium text-gray-900"><%= @bicycle.year %></dd>
        </div>
      <% end %>
      <% if @bicycle.color.present? %>
        <div>
          <dt class="text-gray-400">색상</dt>
          <dd class="font-medium text-gray-900"><%= @bicycle.color %></dd>
        </div>
      <% end %>
      <% if @bicycle.frame_number.present? %>
        <div class="col-span-2">
          <dt class="text-gray-400">프레임번호</dt>
          <dd class="font-medium text-gray-900 text-xs font-mono"><%= @bicycle.frame_number %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>

<div class="mb-6">
  <%= render "lifecycle_reminder", reminder: @lifecycle_reminder, compact: false %>
</div>

<%# Specs grouped by category %>
<% if @grouped_specs.any? %>
  <h2 class="text-lg font-bold text-gray-900 mb-3">사양</h2>
  <div class="space-y-4 mb-6">
    <% @grouped_specs.each do |_key, group| %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4" data-testid="spec-group">
        <h3 class="text-sm font-semibold text-gray-700 mb-3"><%= group[:label] %></h3>
        <dl class="space-y-2">
          <% group[:specs].each do |spec| %>
            <div class="flex justify-between items-baseline text-sm">
              <dt class="text-gray-500"><%= spec.component.titleize %></dt>
              <dd class="text-right text-gray-900 font-medium"><%= spec.brand %> <%= spec.component_model %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>
  </div>
<% end %>
