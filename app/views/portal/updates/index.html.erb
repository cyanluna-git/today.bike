<% content_for(:title) { "업데이트 - Today Bike" } %>

<div class="mb-4">
  <%= link_to portal_root_path, class: "text-sm text-blue-600 hover:text-blue-800" do %>
    &larr; 포털 홈
  <% end %>
</div>

<section class="mb-6 rounded-3xl bg-white p-6 shadow-sm border border-gray-100">
  <h1 class="text-xl font-bold text-gray-900">업데이트 센터</h1>
  <p class="mt-2 text-sm text-gray-500">정비 진행 소식과 일반 안내를 시간순으로 확인할 수 있습니다.</p>
</section>

<% if @updates.any? %>
  <div class="space-y-4">
    <% @updates.each do |update| %>
      <%= render "update_item", update: update %>
    <% end %>
  </div>
<% else %>
  <div class="rounded-3xl border border-dashed border-gray-200 bg-white px-4 py-10 text-center">
    <p class="text-sm font-medium text-gray-700">표시할 업데이트가 없습니다.</p>
    <p class="mt-2 text-sm text-gray-500">정비 진행 또는 일반 안내가 생기면 이곳에 누적됩니다.</p>
  </div>
<% end %>
