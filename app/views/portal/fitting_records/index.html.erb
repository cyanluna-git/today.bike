<% content_for(:title) { "피팅 기록 - Today Bike" } %>

<h1 class="text-xl font-bold text-gray-900 mb-4">피팅 기록</h1>

<% if @fitting_records_by_bicycle.any? %>
  <div class="space-y-6">
    <% @fitting_records_by_bicycle.each do |bicycle, records| %>
      <div data-testid="fitting-bicycle-group">
        <h2 class="text-sm font-semibold text-gray-700 mb-2">
          <%= bicycle.brand %> <%= bicycle.model_label %>
        </h2>
        <div class="space-y-3">
          <% records.each do |record| %>
            <%= link_to portal_fitting_record_path(record), class: "block bg-white rounded-xl shadow-sm border border-gray-100 p-4 hover:shadow-md transition", data: { testid: "fitting-record-card" } do %>
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= record.recorded_at&.strftime("%Y.%m.%d") %></p>
                  <% if record.notes.present? %>
                    <p class="text-xs text-gray-500 mt-1 line-clamp-1"><%= record.notes %></p>
                  <% end %>
                </div>
                <div class="text-right text-xs text-gray-400">
                  <p>안장높이: <%= record.saddle_height %>mm</p>
                  <% if record.stem_length.present? %>
                    <p>스템: <%= record.stem_length %>mm</p>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-12">
    <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
    </svg>
    <p class="text-gray-500">피팅 기록이 없습니다.</p>
  </div>
<% end %>
