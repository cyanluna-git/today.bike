%>

<% content_for(:title, "#{data[:title]} - Today.bike") %>

<% content_for(:meta_tags) do %>
  <meta name="description" content="<%= data[:description].truncate(160) %>">
  <meta property="og:title" content="<%= data[:title] %> - Today.bike">
  <meta property="og:description" content="<%= data[:description].truncate(160) %>">
  <meta property="og:type" content="website">
<% end %>

<div class="w-full max-w-5xl mx-auto">
  <%# Breadcrumb %>
  <div class="mb-6">
    <%= link_to root_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      홈으로
    <% end %>
  </div>

  <%# Header %>
  <section class="mb-12">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-14 h-14 bg-<%= color %>-100 rounded-xl flex items-center justify-center">
        <svg class="w-7 h-7 text-<%= color %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= data[:icon_path] %>" />
          <% if data[:icon_path2] %>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= data[:icon_path2] %>" />
          <% end %>
        </svg>
      </div>
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900"><%= data[:title] %></h1>
        <p class="text-sm text-gray-400"><%= data[:subtitle] %></p>
      </div>
    </div>
    <p class="text-lg text-gray-600 max-w-3xl"><%= data[:description] %></p>
  </section>

  <%# Service Navigation %>
  <nav class="flex gap-2 flex-wrap mb-12" aria-label="Service types">
    <% service_data.each do |type, svc| %>
      <% active = type == @service_type %>
      <%= link_to svc[:title], service_page_path(type),
            class: "px-4 py-2 text-sm font-medium rounded-lg transition #{active ? "bg-#{svc[:color]}-600 text-white" : "bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50"}" %>
    <% end %>
  </nav>

  <%# Process Steps %>
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">서비스 과정</h2>
    <div class="space-y-4">
      <% data[:steps].each_with_index do |step, index| %>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-8 h-8 bg-<%= color %>-600 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0">
              <%= index + 1 %>
            </div>
            <% unless index == data[:steps].length - 1 %>
              <div class="w-0.5 h-full bg-<%= color %>-200 mt-2"></div>
            <% end %>
          </div>
          <div class="pb-6">
            <h3 class="text-base font-semibold text-gray-900"><%= step[:name] %></h3>
            <p class="text-sm text-gray-600 mt-1"><%= step[:desc] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# Pricing %>
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">요금 안내</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="w-full">
        <tbody class="divide-y divide-gray-100">
          <% data[:pricing].each do |item| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= item[:name] %></td>
              <td class="px-6 py-4 text-sm text-gray-600 text-right"><%= item[:price] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 mt-3">* 실제 비용은 자전거 상태에 따라 달라질 수 있습니다. 정확한 견적은 접수 후 안내드립니다.</p>
  </section>

  <%# Showcase Gallery %>
  <% if @showcase_orders.any? %>
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">작업 사례</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @showcase_orders.each do |order| %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <% after_photo = order.service_photos.find { |p| p.photo_type == "after" } %>
            <% if after_photo&.image&.attached? %>
              <%= image_tag after_photo.image.variant(resize_to_limit: [400, 300]), class: "w-full h-48 object-cover" %>
            <% end %>
            <div class="p-3">
              <p class="text-sm font-medium text-gray-900"><%= order.bicycle.brand %> <%= order.bicycle.model_label %></p>
              <p class="text-xs text-gray-500"><%= order.completed_at&.strftime("%Y-%m-%d") %></p>
            </div>
          </div>
        <% end %>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "갤러리에서 더 보기", gallery_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
      </div>
    </section>
  <% end %>

  <%# CTA %>
  <section class="bg-gray-50 rounded-2xl p-8 text-center">
    <h2 class="text-2xl font-bold text-gray-900 mb-3">서비스 문의</h2>
    <p class="text-gray-600 mb-6">카카오톡으로 편하게 문의하세요. 자전거 사진을 함께 보내주시면 더 정확한 안내가 가능합니다.</p>
    <%= link_to "https://pf.kakao.com/_hxaupxb/chat", target: "_blank", rel: "noopener noreferrer",
          class: "inline-flex items-center gap-2 rounded-lg bg-yellow-400 px-6 py-3 text-base font-semibold text-gray-900 shadow-sm hover:bg-yellow-300 transition" do %>
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.47 1.607 4.647 4.042 5.906-.178.663-.647 2.41-.741 2.785-.118.47.173.464.364.337.15-.1 2.38-1.619 3.34-2.275.32.042.65.064.985.064 5.523 0 10-3.477 10-7.817C20 6.477 17.523 3 12 3z"/>
      </svg>
      카카오톡 문의하기
    <% end %>
  </section>
</div>
