<% content_for(:title, "Today.bike - 오늘도 자전거와 함께") %>

<% content_for(:meta_tags) do %>
  <meta name="description" content="투데이바이크 - 충남 천안 자전거 전문 정비 샵. 분해정비, 수리, 피팅, 업그레이드 서비스를 제공합니다.">
  <meta property="og:title" content="투데이바이크 - 오늘도 자전거와 함께">
  <meta property="og:description" content="충남 천안 자전거 전문 정비 샵. 분해정비, 수리, 피팅, 업그레이드 서비스를 제공합니다.">
  <meta property="og:type" content="website">
<% end %>

<% content_for(:json_ld) do %>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Today.bike",
      "description": "투데이바이크 - 충남 천안 자전거 전문 정비 샵. 분해정비, 수리, 피팅, 업그레이드 서비스를 제공합니다.",
      "url": "<%= root_url %>",
      "telephone": "+82-10-4454-5027",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "충남 천안시 동남구 신흥1길 42 1층",
        "addressLocality": "천안시",
        "addressRegion": "충청남도",
        "postalCode": "31127",
        "addressCountry": "KR"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "10:00",
          "closes": "19:00"
        }
      ],
      "priceRange": "$$"
    }
  </script>
<% end %>

<div class="w-full">
  <%# Hero Section %>
  <section class="relative bg-gradient-to-br from-indigo-600 via-indigo-700 to-indigo-900 rounded-2xl overflow-hidden mb-16">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 800 400" fill="none">
        <circle cx="700" cy="200" r="200" stroke="white" stroke-width="1"/>
        <circle cx="700" cy="200" r="150" stroke="white" stroke-width="0.5"/>
        <circle cx="100" cy="200" r="200" stroke="white" stroke-width="1"/>
        <circle cx="100" cy="200" r="150" stroke="white" stroke-width="0.5"/>
      </svg>
    </div>
    <div class="relative px-6 py-20 sm:px-12 sm:py-28 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-4">Today.bike</h1>
      <p class="text-xl sm:text-2xl text-indigo-200 mb-8">오늘도 자전거와 함께</p>
      <p class="text-base sm:text-lg text-indigo-100 max-w-2xl mx-auto mb-10">
        전문 정비사가 당신의 자전거를 최상의 상태로 관리해 드립니다.
        분해정비부터 피팅까지, 모든 서비스를 한 곳에서.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "서비스 보기", service_page_path("overhaul"),
              class: "inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-indigo-700 shadow-sm hover:bg-indigo-50 transition" %>
        <%= link_to "갤러리", gallery_path,
              class: "inline-flex items-center justify-center rounded-lg bg-indigo-500 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-400 transition ring-1 ring-inset ring-indigo-400" %>
      </div>
    </div>
  </section>

  <%# Services Overview %>
  <section class="mb-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">서비스</h2>
      <p class="mt-2 text-gray-600">자전거에 필요한 모든 서비스를 제공합니다</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <%# Overhaul %>
      <%= link_to service_page_path("overhaul"), class: "group bg-white rounded-xl shadow-sm hover:shadow-md p-6 transition border border-gray-100" do %>
        <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-indigo-200 transition">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">분해정비</h3>
        <p class="text-sm text-gray-600">자전거를 완전 분해하여 모든 부품을 세척, 점검, 재조립합니다.</p>
      <% end %>

      <%# Repair %>
      <%= link_to service_page_path("repair"), class: "group bg-white rounded-xl shadow-sm hover:shadow-md p-6 transition border border-gray-100" do %>
        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-green-200 transition">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">수리</h3>
        <p class="text-sm text-gray-600">고장 진단부터 수리까지, 빠르고 정확하게 처리해 드립니다.</p>
      <% end %>

      <%# Fitting %>
      <%= link_to service_page_path("fitting"), class: "group bg-white rounded-xl shadow-sm hover:shadow-md p-6 transition border border-gray-100" do %>
        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-purple-200 transition">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">피팅</h3>
        <p class="text-sm text-gray-600">체형에 맞는 자전거 세팅으로 편안하고 효율적인 라이딩을 도와드립니다.</p>
      <% end %>

      <%# Upgrade %>
      <%= link_to service_page_path("upgrade"), class: "group bg-white rounded-xl shadow-sm hover:shadow-md p-6 transition border border-gray-100" do %>
        <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-amber-200 transition">
          <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">업그레이드</h3>
        <p class="text-sm text-gray-600">구동계, 휠셋, 핸들바 등 원하는 부품으로 업그레이드해 드립니다.</p>
      <% end %>
    </div>
  </section>

  <%# Recent Blog Posts %>
  <% if @recent_posts.any? %>
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">최근 블로그</h2>
          <p class="mt-2 text-gray-600">정비 팁, 리뷰, 샵 소식</p>
        </div>
        <%= link_to "모두 보기", blog_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition hidden sm:block" %>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @recent_posts.each do |post| %>
          <article class="bg-white shadow-sm rounded-xl overflow-hidden hover:shadow-md transition border border-gray-100">
            <% if post.cover_image.attached? %>
              <%= link_to blog_post_path(post.slug) do %>
                <%= image_tag post.cover_image.variant(resize_to_limit: [600, 300]), class: "w-full h-48 object-cover" %>
              <% end %>
            <% else %>
              <%= link_to blog_post_path(post.slug) do %>
                <div class="w-full h-48 bg-gradient-to-br from-indigo-100 to-indigo-50 flex items-center justify-center">
                  <svg class="w-12 h-12 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
              <% end %>
            <% end %>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800"><%= post.category_label %></span>
                <time class="text-xs text-gray-500" datetime="<%= post.published_at&.iso8601 %>"><%= post.published_at&.strftime("%Y-%m-%d") %></time>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                <%= link_to post.title, blog_post_path(post.slug), class: "hover:text-indigo-600 transition" %>
              </h3>
              <p class="text-sm text-gray-600 line-clamp-2"><%= post.excerpt %></p>
            </div>
          </article>
        <% end %>
      </div>
      <div class="mt-6 text-center sm:hidden">
        <%= link_to "블로그 더 보기", blog_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
      </div>
    </section>
  <% end %>

  <%# Shop Info & Location %>
  <section class="mb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <%# Shop Info %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sm:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">매장 안내</h2>
        <dl class="space-y-4">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <dt class="text-sm font-medium text-gray-500">주소</dt>
              <dd class="text-gray-900">충남 천안시 동남구 신흥1길 42 1층</dd>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <dt class="text-sm font-medium text-gray-500">영업시간</dt>
              <dd class="text-gray-900">
                화~토 10:00 - 19:00<br>
                <span class="text-sm text-gray-500">일요일 · 월요일 휴무</span>
              </dd>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div>
              <dt class="text-sm font-medium text-gray-500">전화</dt>
              <dd class="text-gray-900">010-4454-5027</dd>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <dt class="text-sm font-medium text-gray-500">이메일</dt>
              <dd class="text-gray-900">hello@today.bike</dd>
            </div>
          </div>
        </dl>
      </div>

      <%# Map %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
        <iframe class="w-full flex-1 min-h-[300px]"
                src="https://www.openstreetmap.org/export/embed.html?bbox=127.1218%2C36.7777%2C127.1278%2C36.7817&layer=mapnik&marker=36.7797%2C127.1248"
                loading="lazy"
                title="투데이바이크 위치"></iframe>
        <a href="https://map.kakao.com/?q=%EC%B6%A9%EB%82%A8+%EC%B2%9C%EC%95%88%EC%8B%9C+%EB%8F%99%EB%82%A8%EA%B5%AC+%EC%8B%A0%ED%9D%A51%EA%B8%B8+42"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-2 px-4 py-3 text-sm font-medium text-indigo-600 hover:bg-indigo-50 transition border-t border-gray-100">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          카카오맵에서 길찾기
        </a>
      </div>
    </div>
  </section>
</div>
