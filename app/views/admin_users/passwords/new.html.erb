<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Today Bike</h1>
      <p class="text-sm text-gray-500 mt-1">Admin Panel</p>
    </div>

    <div class="bg-white shadow-md rounded-lg px-8 py-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">Forgot your password?</h2>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "admin_users/shared/error_messages", resource: resource %>

        <div class="mb-6">
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" %>
        </div>

        <div>
          <%= f.submit "Send me reset password instructions",
              class: "w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="mt-4 text-center text-sm text-gray-500">
      <p><%= link_to "Back to login", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-500" %></p>
    </div>
  </div>
</div>
