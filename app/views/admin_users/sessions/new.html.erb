<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <svg class="w-10 h-10 text-indigo-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <circle cx="7" cy="17" r="3" stroke-width="2"/>
      <circle cx="17" cy="17" r="3" stroke-width="2"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17L14 7h-4l3 10M7 17l3-10"/>
    </svg>
    <h1 class="text-2xl font-bold text-gray-900">투데이바이크</h1>
    <p class="text-sm text-gray-500 mt-1">관리자 로그인</p>
  </div>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 px-8 py-8">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-5">
        <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "admin@today.bike",
            class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, "비밀번호", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
          <%= f.label :remember_me, "로그인 유지", class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "로그인",
            class: "w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer transition" %>
      </div>
    <% end %>
  </div>

  <p class="mt-6 text-center text-xs text-gray-400">&copy; <%= Date.current.year %> Today.bike</p>
</div>
