<% content_for(:title, "피팅기록 수정 - #{@bicycle.brand} #{@bicycle.model_label} - Admin - Today Bike") %>

<div class="w-full">
  <div class="mb-6">
    <%= link_to admin_bicycle_fitting_record_path(@bicycle, @fitting_record), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      피팅기록 상세
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">피팅기록 수정</h1>
  <p class="text-sm text-gray-500 mb-6"><%= @bicycle.brand %> <%= @bicycle.model_label %> &mdash; <%= @fitting_record.recorded_at.strftime("%Y-%m-%d %H:%M") %></p>

  <%= render "form", bicycle: @bicycle, fitting_record: @fitting_record %>
</div>
