<%= form_with(model: fitting_record, url: fitting_record.persisted? ? admin_bicycle_fitting_record_path(@bicycle, fitting_record) : admin_bicycle_fitting_records_path(@bicycle), class: "space-y-8") do |form| %>
  <% if fitting_record.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(fitting_record.errors.count, "error") %> prohibited this record from being saved:</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc space-y-1 pl-5">
              <% fitting_record.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Recording Info %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">기록 정보</legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :recorded_at, "기록일시", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.datetime_local_field :recorded_at, value: fitting_record.recorded_at&.strftime("%Y-%m-%dT%H:%M"), class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :service_order_id, "서비스오더", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.select :service_order_id,
              options_from_collection_for_select(@bicycle.service_orders.order(created_at: :desc), :id, :order_number, fitting_record.service_order_id),
              { include_blank: "— 없음 —" },
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
    </div>
  </fieldset>

  <%# Saddle %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">안장 (Saddle)</legend>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= form.label :saddle_height, "안장 높이 (mm) *", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :saddle_height, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :saddle_setback, "안장 후퇴량 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :saddle_setback, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :saddle_tilt, "안장 기울기 (degrees)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :saddle_tilt, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :saddle_brand, "안장 브랜드", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :saddle_brand, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :saddle_model, "안장 모델", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :saddle_model, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
    </div>
  </fieldset>

  <%# Handlebar %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">핸들바 (Handlebar)</legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <%= form.label :handlebar_width, "폭 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :handlebar_width, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :handlebar_drop, "드롭 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :handlebar_drop, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :handlebar_reach, "리치 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :handlebar_reach, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :handlebar_stack, "스택 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :handlebar_stack, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
    </div>
  </fieldset>

  <%# Stem %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">스템 (Stem)</legend>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= form.label :stem_length, "길이 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :stem_length, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :stem_angle, "각도 (degrees)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :stem_angle, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
      <div>
        <%= form.label :stem_spacer, "스페이서 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :stem_spacer, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
    </div>
  </fieldset>

  <%# Crank %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">크랭크 (Crank)</legend>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= form.label :crank_length, "길이 (mm)", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.number_field :crank_length, step: 0.1, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
      </div>
    </div>
  </fieldset>

  <%# Cleat %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">클릿 (Cleat)</legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :cleat_left, "왼발 클릿", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :cleat_left, rows: 3, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", placeholder: "위치 및 각도 설명" %>
      </div>
      <div>
        <%= form.label :cleat_right, "오른발 클릿", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :cleat_right, rows: 3, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", placeholder: "위치 및 각도 설명" %>
      </div>
    </div>
  </fieldset>

  <%# Notes %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">메모</legend>
    <div>
      <%= form.label :notes, "비고", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :notes, rows: 4, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
    </div>
  </fieldset>

  <%# Photos %>
  <fieldset class="border border-gray-200 rounded-lg p-6">
    <legend class="text-sm font-semibold text-gray-900 px-2">사진</legend>
    <div>
      <%= form.label :photos, "피팅 사진", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.file_field :photos, multiple: true, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
      <p class="mt-1 text-xs text-gray-500">JPEG, PNG, WebP, HEIC (최대 10MB)</p>
    </div>
  </fieldset>

  <div class="flex items-center gap-4">
    <%= form.submit fitting_record.persisted? ? "수정" : "저장", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition cursor-pointer" %>
    <%= link_to "취소", fitting_record.persisted? ? admin_bicycle_fitting_record_path(@bicycle, fitting_record) : admin_bicycle_fitting_records_path(@bicycle), class: "text-sm font-semibold text-gray-700 hover:text-gray-900 transition" %>
  </div>
<% end %>
