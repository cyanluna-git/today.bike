<% content_for(:title, "New Customer - Admin - Today Bike") %>

<div class="w-full max-w-2xl">
  <div class="mb-6">
    <% back_path = @source_inquiry.present? ? admin_service_inquiry_path(@source_inquiry) : admin_customers_path %>
    <%= link_to back_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <%= @source_inquiry.present? ? "문의 상세로 돌아가기" : "Back to Customers" %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= @source_inquiry.present? ? "문의에서 고객 생성" : "New Customer" %></h1>

  <% if @source_inquiry.present? %>
    <div class="mb-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-900">
      <p class="font-semibold">문의 접수에서 고객을 생성합니다.</p>
      <p class="mt-1"><%= @source_inquiry.name %> · <%= @source_inquiry.phone %></p>
      <p class="mt-2 text-amber-800">
        기존 전화번호 고객 후보가 이미 있으면 같은 번호로는 저장되지 않습니다. 별도 고객으로 분리해야 하면 연락처를 조정하거나 메모에 관계를 남겨 주세요.
      </p>
    </div>
  <% end %>

  <%= render "form", customer: @customer, service_inquiry: @source_inquiry %>
</div>
