<% content_for(:title, "문의 접수 - Admin - Today Bike") %>

<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">문의 접수</h1>
      <p class="mt-1 text-sm text-gray-500">공개 웹에서 들어온 문의와 접수 요청을 확인합니다.</p>
    </div>
  </div>

  <nav class="mb-4 flex gap-2" aria-label="Inquiry status filter">
    <%= link_to "전체", admin_service_inquiries_path, class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:status].blank? ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50'} transition" %>
    <% ServiceInquiry.statuses.keys.each do |status| %>
      <%= link_to ServiceInquiry::STATUS_LABELS[status], admin_service_inquiries_path(status: status), class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:status] == status ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50'} transition" %>
    <% end %>
  </nav>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">고객</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">분류</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">유입</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">희망 방문일</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @service_inquiries.each do |inquiry| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to inquiry.name, admin_service_inquiry_path(inquiry), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              <span class="block text-xs text-gray-500"><%= inquiry.phone %></span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= inquiry.request_category_label %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= inquiry.source_label %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= inquiry.desired_visit_on || "-" %></td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= inquiry.status == 'pending' ? 'bg-amber-100 text-amber-800' : inquiry.status == 'in_review' ? 'bg-sky-100 text-sky-800' : 'bg-emerald-100 text-emerald-800' %>">
                <%= inquiry.status_label %>
              </span>
            </td>
          </tr>
        <% end %>
        <% if @service_inquiries.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-sm text-gray-500">접수된 문의가 없습니다.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
