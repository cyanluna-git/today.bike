<%= form_with(model: [:admin, blog_post], class: "space-y-6") do |form| %>
  <% if blog_post.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(blog_post.errors.count, "error") %> prohibited this blog post from being saved:
          </h3>
          <ul class="mt-2 list-disc list-inside text-sm text-red-700">
            <% blog_post.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 space-y-6">
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true %>
    </div>

    <div>
      <%= form.label :category, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :category, BlogPost::CATEGORY_LABELS.map { |k, v| [v, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :content, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= form.rich_text_area :content, class: "min-h-64" %>
      </div>
    </div>

    <div>
      <%= form.label :cover_image, "Cover Image", class: "block text-sm font-medium text-gray-700" %>
      <%= form.file_field :cover_image,
            accept: "image/jpeg,image/png,image/webp",
            class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100",
            direct_upload: true %>
      <% if blog_post.persisted? && blog_post.cover_image.attached? %>
        <div class="mt-2">
          <%= image_tag blog_post.cover_image.variant(resize_to_limit: [400, 200]), class: "rounded-md" %>
        </div>
      <% end %>
    </div>

    <div>
      <%= form.label :author, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :author, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :meta_description, "Meta Description (SEO)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :meta_description, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Search engine description..." %>
    </div>

    <div>
      <%= form.label :source_url, "Source URL", class: "block text-sm font-medium text-gray-700" %>
      <%= form.url_field :source_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "https://blog.naver.com/..." %>
    </div>

    <div class="flex items-center gap-2">
      <%= form.check_box :published, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
      <%= form.label :published, "Published", class: "text-sm font-medium text-gray-700" %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", (blog_post.persisted? ? admin_blog_post_path(blog_post) : admin_blog_posts_path), class: "rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
    <%= form.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition cursor-pointer" %>
  </div>
<% end %>
