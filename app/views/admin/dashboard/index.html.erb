<% content_for(:title, "Dashboard - Admin - Today Bike") %>

<div class="w-full">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

  <%# Stats cards %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Total Customers</p>
          <p class="mt-1 text-3xl font-bold text-gray-900"><%= @total_customers %></p>
        </div>
        <div class="bg-indigo-50 rounded-lg p-3">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Total Bicycles</p>
          <p class="mt-1 text-3xl font-bold text-gray-900"><%= @total_bicycles %></p>
        </div>
        <div class="bg-green-50 rounded-lg p-3">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Active Orders</p>
          <p class="mt-1 text-3xl font-bold text-gray-900"><%= @active_service_orders %></p>
        </div>
        <div class="bg-yellow-50 rounded-lg p-3">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Completed This Month</p>
          <p class="mt-1 text-3xl font-bold text-gray-900"><%= @completed_this_month %></p>
        </div>
        <div class="bg-purple-50 rounded-lg p-3">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Status distribution %>
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Status Distribution</h2>
      <div class="space-y-3">
        <% ServiceOrder::STATUS_ORDER.each do |status| %>
          <% count = @status_counts[status] || 0 %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-600 capitalize"><%= status.titleize %></span>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= case status
                  when 'received' then 'bg-blue-100 text-blue-800'
                  when 'diagnosis' then 'bg-yellow-100 text-yellow-800'
                  when 'in_progress' then 'bg-orange-100 text-orange-800'
                  when 'completed' then 'bg-green-100 text-green-800'
                  when 'delivered' then 'bg-gray-100 text-gray-800'
                  end %>">
              <%= count %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Today's summary %>
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Today</h2>
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="bg-green-50 rounded-lg p-2">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-gray-500">Completed</p>
            <p class="text-xl font-bold text-gray-900"><%= @today_completed %></p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="bg-blue-50 rounded-lg p-2">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-gray-500">Delivered</p>
            <p class="text-xl font-bold text-gray-900"><%= @today_delivered %></p>
          </div>
        </div>
      </div>
    </div>

    <%# Quick links %>
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h2>
      <div class="space-y-2">
        <%= link_to new_admin_service_order_path, class: "block w-full text-left px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-50 transition" do %>
          + New Service Order
        <% end %>
        <%= link_to new_admin_customer_path, class: "block w-full text-left px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-50 transition" do %>
          + New Customer
        <% end %>
        <%= link_to new_admin_bicycle_path, class: "block w-full text-left px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-50 transition" do %>
          + New Bicycle
        <% end %>
        <%= link_to kanban_admin_service_orders_path, class: "block w-full text-left px-3 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-50 transition" do %>
          View Kanban Board
        <% end %>
      </div>
    </div>
  </div>

  <%# Recent service orders %>
  <div class="mt-6 bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Recent Service Orders</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order #</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Bicycle</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Received</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_service_orders.each do |order| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <%= link_to order.order_number, admin_service_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= order.bicycle.customer.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= "#{order.bicycle.brand} #{order.bicycle.model_label}" %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                  <%= case order.status
                      when 'received' then 'bg-blue-100 text-blue-800'
                      when 'diagnosis' then 'bg-yellow-100 text-yellow-800'
                      when 'in_progress' then 'bg-orange-100 text-orange-800'
                      when 'completed' then 'bg-green-100 text-green-800'
                      when 'delivered' then 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= order.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= order.received_at.strftime("%Y-%m-%d") %></td>
            </tr>
          <% end %>
          <% if @recent_service_orders.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-500">No service orders yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
