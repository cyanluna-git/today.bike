<div id="<%= dom_id(service_photo) %>" class="group relative">
  <% if service_photo.image.attached? %>
    <div class="aspect-square overflow-hidden rounded-lg bg-gray-100 cursor-pointer"
         data-action="click->lightbox#open"
         data-lightbox-url-param="<%= rails_blob_path(service_photo.image, only_path: true) %>"
         data-lightbox-caption-param="<%= service_photo.caption %>">
      <%= image_tag service_photo.thumbnail, class: "h-full w-full object-cover", loading: "lazy", alt: service_photo.caption || service_photo.type_label %>
    </div>
  <% else %>
    <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
      <div class="flex h-full items-center justify-center">
        <svg class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v13.5A1.5 1.5 0 003.75 21z" />
        </svg>
      </div>
    </div>
  <% end %>
  <div class="mt-2">
    <p class="text-xs text-gray-500"><%= service_photo.type_label %></p>
    <% if service_photo.caption.present? %>
      <p class="text-xs text-gray-700 truncate" title="<%= service_photo.caption %>"><%= service_photo.caption %></p>
    <% end %>
    <% if service_photo.taken_at.present? %>
      <p class="text-xs text-gray-400"><%= service_photo.taken_at.strftime("%Y-%m-%d %H:%M") %></p>
    <% end %>
  </div>
  <div class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= button_to admin_service_order_service_photo_path(service_photo.service_order, service_photo),
          method: :delete,
          class: "rounded-full bg-red-600 p-1 text-white shadow-sm hover:bg-red-500 transition",
          form: { data: { turbo_confirm: "Delete this photo?" } } do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    <% end %>
  </div>
</div>
