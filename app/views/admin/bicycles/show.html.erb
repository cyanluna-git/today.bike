<% content_for(:title, "#{@bicycle.brand} #{@bicycle.model_label} - Bicycles - Admin - Today Bike") %>

<div class="w-full">
  <div class="mb-6">
    <%= link_to admin_bicycles_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Bicycles
    <% end %>
  </div>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @bicycle.brand %> <%= @bicycle.model_label %></h1>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_bicycle_path(@bicycle), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
      <%= button_to "Delete", admin_bicycle_path(@bicycle), method: :delete,
            class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition",
            form: { data: { turbo_confirm: "Are you sure you want to delete this bicycle?" } } %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <dl class="divide-y divide-gray-200">
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Brand</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.brand %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Model</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.model_label %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Year</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.year.presence || "—" %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Frame Number</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.frame_number.presence || "—" %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Type</dt>
        <dd class="mt-1 sm:col-span-2 sm:mt-0">
          <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= @bicycle.bike_type.titleize %></span>
        </dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Color</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.color.presence || "—" %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Status</dt>
        <dd class="mt-1 sm:col-span-2 sm:mt-0">
          <% case @bicycle.status %>
          <% when "active" %>
            <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Active</span>
          <% when "sold" %>
            <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">Sold</span>
          <% when "scrapped" %>
            <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">Scrapped</span>
          <% end %>
        </dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Customer</dt>
        <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
          <%= link_to @bicycle.customer.name, admin_customer_path(@bicycle.customer), class: "text-indigo-600 hover:text-indigo-900 transition" %>
        </dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Created at</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.created_at.strftime("%Y-%m-%d %H:%M") %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Updated at</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.updated_at.strftime("%Y-%m-%d %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Spec Summary (grouped card view) %>
  <%= render "admin/bicycle_specs/spec_summary", bicycle: @bicycle %>

  <%# Component Specs (inline CRUD table) %>
  <%= render "admin/bicycle_specs/specs_list", bicycle: @bicycle %>

  <%# Fitting Records %>
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">피팅기록</h2>
      <%= link_to "전체보기", admin_bicycle_fitting_records_path(@bicycle), class: "text-sm text-indigo-600 hover:text-indigo-900 transition" %>
    </div>
    <% latest_fitting = @bicycle.fitting_records.order(recorded_at: :desc).first %>
    <% if latest_fitting %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <dl class="divide-y divide-gray-200">
          <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500">기록일</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
              <%= link_to latest_fitting.recorded_at.strftime("%Y-%m-%d %H:%M"), admin_bicycle_fitting_record_path(@bicycle, latest_fitting), class: "text-indigo-600 hover:text-indigo-900" %>
            </dd>
          </div>
          <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500">안장 높이</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= latest_fitting.saddle_height.present? ? "#{latest_fitting.saddle_height} mm" : "—" %></dd>
          </div>
          <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500">스템 길이</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= latest_fitting.stem_length.present? ? "#{latest_fitting.stem_length} mm" : "—" %></dd>
          </div>
          <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500">핸들바 폭</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= latest_fitting.handlebar_width.present? ? "#{latest_fitting.handlebar_width} mm" : "—" %></dd>
          </div>
          <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500">크랭크 길이</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= latest_fitting.crank_length.present? ? "#{latest_fitting.crank_length} mm" : "—" %></dd>
          </div>
        </dl>
        <div class="px-6 py-3 bg-gray-50 border-t border-gray-200">
          <span class="text-xs text-gray-500">총 <%= @bicycle.fitting_records.count %>건의 피팅기록</span>
        </div>
      </div>
    <% else %>
      <div class="bg-white shadow rounded-lg p-6 text-center">
        <p class="text-sm text-gray-500 mb-3">피팅기록이 없습니다.</p>
        <%= link_to "새 피팅기록 추가", new_admin_bicycle_fitting_record_path(@bicycle), class: "text-sm text-indigo-600 hover:text-indigo-900 transition" %>
      </div>
    <% end %>
  </div>

  <%# QR Code / Bicycle Passport %>
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">QR Code / Passport</h2>
      <div class="flex items-center gap-2">
        <%= link_to "Download PNG", qr_code_admin_bicycle_path(@bicycle, format: :png), class: "inline-flex items-center rounded-md bg-white px-3 py-1.5 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
        <%= link_to "Print", qr_print_admin_bicycle_path(@bicycle), target: "_blank", class: "inline-flex items-center rounded-md bg-white px-3 py-1.5 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
        <% if @bicycle.passport_token.present? %>
          <%= link_to "View Passport", passport_path(@bicycle.passport_token), target: "_blank", class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-500 transition" %>
        <% end %>
      </div>
    </div>
    <div class="bg-white shadow rounded-lg p-6 flex items-center justify-center">
      <% if @bicycle.passport_token.present? %>
        <%= raw QrCodeService.generate_svg(@bicycle.passport_url) %>
      <% else %>
        <p class="text-sm text-gray-500">QR code will be generated when you download or print it.</p>
      <% end %>
    </div>
  </div>

  <%# Photo Gallery %>
  <% if @bicycle.photos.attached? %>
    <div class="mt-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Photos</h2>
      <div id="photo_gallery" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <% @bicycle.photos.each do |photo| %>
          <div id="photo_<%= photo.id %>" class="relative group">
            <a href="<%= url_for(photo) %>" target="_blank">
              <%= image_tag @bicycle.photo_thumbnail(photo), class: "w-full h-40 object-cover rounded-lg shadow-sm hover:shadow-md transition" %>
            </a>
            <div class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition">
              <%= button_to purge_photo_admin_bicycle_path(@bicycle, photo_id: photo.id),
                    method: :delete,
                    class: "rounded-full bg-red-600 p-1.5 text-white shadow-sm hover:bg-red-500 transition",
                    form: { data: { turbo_confirm: "Delete this photo?" } } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
