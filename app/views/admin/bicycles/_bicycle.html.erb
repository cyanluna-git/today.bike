<tr id="<%= dom_id(bicycle) %>">
  <td class="px-6 py-4 whitespace-nowrap">
    <div class="text-sm font-medium text-gray-900">
      <%= link_to "#{bicycle.brand} #{bicycle.model_label}", admin_bicycle_path(bicycle), class: "hover:text-indigo-600 transition", data: { turbo_frame: "_top" } %>
    </div>
    <% if bicycle.year.present? %>
      <div class="text-xs text-gray-500"><%= bicycle.year %></div>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= link_to bicycle.customer.name, admin_customer_path(bicycle.customer), class: "text-indigo-600 hover:text-indigo-900 transition", data: { turbo_frame: "_top" } %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= bicycle.bike_type.titleize %></span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <% case bicycle.status %>
    <% when "active" %>
      <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Active</span>
    <% when "sold" %>
      <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">Sold</span>
    <% when "scrapped" %>
      <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">Scrapped</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
    <%= link_to "Edit", edit_admin_bicycle_path(bicycle), class: "text-indigo-600 hover:text-indigo-900 transition" %>
    <%= button_to "Delete", admin_bicycle_path(bicycle), method: :delete,
          class: "text-red-600 hover:text-red-900 transition",
          form: { data: { turbo_confirm: "Are you sure you want to delete this bicycle?" } } %>
  </td>
</tr>
