<% content_for(:title, "New Bicycle - Admin - Today Bike") %>

<div class="w-full max-w-2xl">
  <div class="mb-6">
    <% back_path = @source_inquiry.present? ? admin_service_inquiry_path(@source_inquiry) : admin_bicycles_path %>
    <%= link_to back_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <%= @source_inquiry.present? ? "문의 상세로 돌아가기" : "Back to Bicycles" %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= @source_inquiry.present? ? "문의에서 자전거 생성" : "New Bicycle" %></h1>

  <% if @source_inquiry.present? %>
    <div class="mb-6 rounded-2xl border border-sky-200 bg-sky-50 px-5 py-4 text-sm text-sky-900">
      <p class="font-semibold">문의에서 자전거를 생성합니다.</p>
      <p class="mt-1"><%= @source_inquiry.customer&.name || @source_inquiry.name %> 고객에 연결됩니다.</p>
      <p class="mt-2 text-sky-800">생성 후 문의 상세로 돌아가 대표 자전거로 자동 연결됩니다.</p>
    </div>
  <% end %>

  <%= render "form", bicycle: @bicycle, service_inquiry: @source_inquiry %>
</div>
