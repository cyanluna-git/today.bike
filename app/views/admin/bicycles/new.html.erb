<% content_for(:title, "New Bicycle - Admin - Today Bike") %>

<div class="w-full max-w-2xl">
  <div class="mb-6">
    <%= link_to admin_bicycles_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Bicycles
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Bicycle</h1>

  <%= render "form", bicycle: @bicycle %>
</div>
