<% content_for(:title, "New Booking - #{@rental.name} - Admin - Today Bike") %>

<div class="w-full max-w-3xl">
  <div class="mb-6">
    <%= link_to admin_rental_rental_bookings_path(@rental), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Bookings
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Booking - <%= @rental.name %></h1>

  <%= render "form", rental_booking: @rental_booking %>
</div>
