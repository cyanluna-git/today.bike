<% content_for(:title, "가져오기 결과 - Admin - Today Bike") %>

<div class="w-full max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">가져오기 결과</h1>

  <div class="bg-white shadow rounded-lg p-6 space-y-6">
    <%# Summary cards %>
    <div class="grid grid-cols-3 gap-4">
      <div class="bg-green-50 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-green-700"><%= @result[:created] %></p>
        <p class="text-sm text-green-600">생성됨</p>
      </div>
      <div class="bg-yellow-50 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-yellow-700"><%= @result[:skipped] %></p>
        <p class="text-sm text-yellow-600">건너뜀</p>
      </div>
      <div class="bg-red-50 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-red-700"><%= @result[:errors].size %></p>
        <p class="text-sm text-red-600">오류</p>
      </div>
    </div>

    <%# Errors list %>
    <% if @result[:errors].any? %>
      <div class="border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-700 mb-2">오류 목록</h3>
        <ul class="list-disc list-inside text-sm text-red-600 space-y-1 max-h-60 overflow-y-auto">
          <% @result[:errors].each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex items-center gap-3">
      <%= link_to "다시 가져오기", new_admin_import_path, class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" %>
      <%= link_to "대시보드로", admin_root_path, class: "inline-flex items-center gap-2 rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
    </div>
  </div>
</div>
