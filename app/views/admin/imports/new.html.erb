<% content_for(:title, "데이터 가져오기 - Admin - Today Bike") %>

<div class="w-full max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">데이터 가져오기</h1>

  <div class="bg-white shadow rounded-lg p-6">
    <%= form_with url: admin_imports_path, method: :post, multipart: true, class: "space-y-6" do |f| %>
      <div>
        <label for="import_type" class="block text-sm font-medium text-gray-700 mb-1">가져오기 유형</label>
        <%= f.select :import_type,
              options_for_select([["고객 (Customers)", "customers"], ["자전거 (Bicycles)", "bicycles"]], @import_type),
              {},
              class: "block w-full rounded-md border-0 py-2 pl-3 pr-10 text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6",
              id: "import_type" %>
      </div>

      <div>
        <label for="file" class="block text-sm font-medium text-gray-700 mb-1">CSV 파일</label>
        <%= f.file_field :file, accept: ".csv", id: "file",
              class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer" %>
        <p class="mt-1 text-xs text-gray-500">UTF-8 또는 Shift-JIS 인코딩의 CSV 파일을 업로드하세요.</p>
      </div>

      <div class="bg-gray-50 rounded-md p-4">
        <h3 class="text-sm font-medium text-gray-700 mb-2">CSV 형식 안내</h3>
        <div class="text-xs text-gray-500 space-y-2">
          <div>
            <p class="font-medium text-gray-600">고객 (Customers):</p>
            <code class="bg-gray-100 px-1 py-0.5 rounded">name, phone, email, memo</code>
          </div>
          <div>
            <p class="font-medium text-gray-600">자전거 (Bicycles):</p>
            <code class="bg-gray-100 px-1 py-0.5 rounded">customer_phone, brand, model_label, year, bike_type, frame_number, color</code>
          </div>
        </div>
      </div>

      <div>
        <%= f.submit "가져오기",
              class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
