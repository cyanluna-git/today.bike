<% content_for(:title, "파츠/용품 관리 - Admin - Today Bike") %>

<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">파츠/용품 관리</h1>
    <%= link_to new_admin_product_path, class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Product
    <% end %>
  </div>

  <%# Category filter tabs %>
  <div class="mb-4">
    <nav class="flex gap-2 flex-wrap" aria-label="Category filter">
      <%= link_to "All", admin_products_path, class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:category].blank? ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50'} transition" %>
      <% Product::CATEGORY_LABELS.each do |key, label| %>
        <%= link_to label, admin_products_path(category: key), class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:category] == key ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50'} transition" %>
      <% end %>
    </nav>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Image</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Active</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @products.each do |product| %>
          <tr>
            <td class="px-6 py-4">
              <% if product.images.attached? %>
                <%= image_tag product.images.first.variant(resize_to_limit: [60, 60]), class: "w-10 h-10 rounded object-cover" %>
              <% else %>
                <div class="w-10 h-10 rounded bg-gray-100 flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                </div>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-900">
              <%= link_to product.name, admin_product_path(product), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              <% if product.brand.present? %>
                <span class="block text-xs text-gray-500"><%= product.brand %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm">
              <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= product.category_label %></span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-900">
              <% if product.on_sale? %>
                <span class="line-through text-gray-400"><%= number_to_currency(product.price, unit: "₩", precision: 0) %></span>
                <span class="text-red-600 font-medium block"><%= number_to_currency(product.sale_price, unit: "₩", precision: 0) %></span>
              <% else %>
                <%= number_to_currency(product.price, unit: "₩", precision: 0) %>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-900">
              <% if product.stock_quantity > 0 %>
                <span class="text-green-700"><%= product.stock_quantity %></span>
              <% else %>
                <span class="text-red-600">0</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm">
              <% if product.active? %>
                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Active</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">Inactive</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right text-sm">
              <div class="flex items-center justify-end gap-2">
                <%= link_to "Edit", edit_admin_product_path(product), class: "text-indigo-600 hover:text-indigo-900" %>
                <%= button_to "Delete", admin_product_path(product), method: :delete,
                      class: "text-red-600 hover:text-red-900",
                      form: { data: { turbo_confirm: "Are you sure?" } } %>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @products.empty? %>
          <tr>
            <td colspan="7" class="px-6 py-12 text-center text-sm text-gray-500">
              No products yet. <%= link_to "Create the first one", new_admin_product_path, class: "text-indigo-600 hover:text-indigo-500 font-medium" %>.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @pagy.pages > 1 %>
      <div class="border-t border-gray-200 bg-white px-4 py-3 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="text-sm text-gray-700">
            Total <span class="font-medium"><%= @pagy.count %></span> products
          </div>
          <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
            <% if @pagy.prev %>
              <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" do %>
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" /></svg>
              <% end %>
            <% end %>
            <% @pagy.series.each do |item| %>
              <% case item %>
              <% when Integer %>
                <%= link_to item, pagy_url_for(@pagy, item), class: "relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
              <% when String %>
                <span aria-current="page" class="relative z-10 inline-flex items-center bg-indigo-600 px-4 py-2 text-sm font-semibold text-white"><%= item %></span>
              <% when :gap %>
                <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-700 ring-1 ring-inset ring-gray-300">&hellip;</span>
              <% end %>
            <% end %>
            <% if @pagy.next %>
              <%= link_to pagy_url_for(@pagy, @pagy.next), class: "relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" do %>
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
              <% end %>
            <% end %>
          </nav>
        </div>
      </div>
    <% end %>
  </div>
</div>
