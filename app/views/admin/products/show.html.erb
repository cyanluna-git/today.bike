<% content_for(:title, "#{@product.name} - Products - Admin - Today Bike") %>

<div class="w-full">
  <div class="mb-6">
    <%= link_to admin_products_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Products
    <% end %>
  </div>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @product.name %></h1>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_product_path(@product), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
      <%= button_to "Delete", admin_product_path(@product), method: :delete,
            class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition",
            form: { data: { turbo_confirm: "Are you sure you want to delete this product?" } } %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <dl class="divide-y divide-gray-200">
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Category</dt>
        <dd class="mt-1 sm:col-span-2 sm:mt-0">
          <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= @product.category_label %></span>
        </dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Brand</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @product.brand || "-" %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Price</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <% if @product.on_sale? %>
            <span class="line-through text-gray-400 mr-2"><%= number_to_currency(@product.price, unit: "₩", precision: 0) %></span>
            <span class="text-red-600 font-medium"><%= number_to_currency(@product.sale_price, unit: "₩", precision: 0) %></span>
          <% else %>
            <%= number_to_currency(@product.price, unit: "₩", precision: 0) %>
          <% end %>
        </dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Stock</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @product.stock_quantity %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">SKU</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @product.sku || "-" %></dd>
      </div>
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Status</dt>
        <dd class="mt-1 sm:col-span-2 sm:mt-0">
          <% if @product.active? %>
            <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Active</span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">Inactive</span>
          <% end %>
        </dd>
      </div>
      <% if @product.description.present? %>
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Description</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= simple_format(@product.description) %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <%# Image Gallery %>
  <% if @product.images.attached? %>
    <div class="mt-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Images</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <% @product.images.each do |image| %>
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <%= image_tag image.variant(resize_to_limit: [400, 400]), class: "w-full h-48 object-cover" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
