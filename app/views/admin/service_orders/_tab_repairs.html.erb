<div class="space-y-4">
  <%# New repair log form %>
  <%= render "admin/repair_logs/form", service_order: service_order, repair_log: RepairLog.new %>

  <%# Repair logs list %>
  <div id="repair_logs_list" class="space-y-3">
    <% repair_logs = service_order.repair_logs.ordered %>
    <% if repair_logs.any? %>
      <% repair_logs.each do |repair_log| %>
        <%= render "admin/repair_logs/repair_log", repair_log: repair_log %>
      <% end %>
    <% else %>
      <div id="repair_logs_empty" class="bg-white shadow rounded-lg overflow-hidden">
        <div class="px-6 py-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900">수리내역 없음</h3>
          <p class="mt-1 text-sm text-gray-500">위 폼을 사용하여 수리내역을 추가하세요.</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
