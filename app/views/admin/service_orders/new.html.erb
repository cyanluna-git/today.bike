<% content_for(:title, "New Service Order - Admin - Today Bike") %>

<div class="w-full max-w-2xl">
  <div class="mb-6">
    <% back_path = @source_inquiry.present? ? admin_service_inquiry_path(@source_inquiry) : admin_service_orders_path %>
    <%= link_to back_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <%= @source_inquiry.present? ? "문의 상세로 돌아가기" : "Back to Service Orders" %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= @source_inquiry.present? ? "문의에서 서비스오더 생성" : "New Service Order" %></h1>

  <% if @source_inquiry.present? %>
    <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-900">
      <p class="font-semibold">문의에서 서비스오더를 생성합니다.</p>
      <p class="mt-1"><%= @source_inquiry.bicycle ? "#{@source_inquiry.bicycle.brand} #{@source_inquiry.bicycle.model_label}" : "연결된 자전거" %> 기준으로 접수 정보가 미리 채워집니다.</p>
      <p class="mt-2 text-emerald-800">서비스 유형과 문의 요약만 보수적으로 채우고, 비용과 완료 정보는 운영자가 별도로 확정합니다.</p>
    </div>
  <% end %>

  <%= render "form", service_order: @service_order, service_inquiry: @source_inquiry %>
</div>
