<% content_for(:title, "#{@service_order.order_number} - 서비스오더 - Admin - Today Bike") %>

<div class="w-full">
  <div class="mb-6">
    <%= link_to admin_service_orders_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Service Orders
    <% end %>
  </div>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @service_order.order_number %></h1>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_service_order_path(@service_order), class: "inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
      <%= button_to "Delete", admin_service_order_path(@service_order), method: :delete,
            class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition",
            form: { data: { turbo_confirm: "Are you sure you want to delete this service order?" } } %>
    </div>
  </div>

  <%# Tab Navigation %>
  <div data-controller="tabs" data-tabs-default-tab-value="basic_info">
    <div class="border-b border-gray-200 mb-6">
      <nav class="-mb-px flex space-x-8" aria-label="Service order tabs">
        <button type="button"
                data-tabs-target="tab"
                data-tab-name="basic_info"
                data-action="click->tabs#switch"
                aria-selected="true"
                class="whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium border-indigo-500 text-indigo-600">
          기본정보
        </button>
        <button type="button"
                data-tabs-target="tab"
                data-tab-name="progress"
                data-action="click->tabs#switch"
                aria-selected="false"
                class="whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700">
          진행상황
        </button>
        <button type="button"
                data-tabs-target="tab"
                data-tab-name="photos"
                data-action="click->tabs#switch"
                aria-selected="false"
                class="whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700">
          정비사진
        </button>
        <button type="button"
                data-tabs-target="tab"
                data-tab-name="parts"
                data-action="click->tabs#switch"
                aria-selected="false"
                class="whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700">
          부품교체
        </button>
        <button type="button"
                data-tabs-target="tab"
                data-tab-name="repairs"
                data-action="click->tabs#switch"
                aria-selected="false"
                class="whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700">
          수리내역
        </button>
      </nav>
    </div>

    <%# Tab Panels %>
    <turbo-frame id="service_order_tab_basic_info" data-tabs-target="panel" data-tab-name="basic_info">
      <%= render "admin/service_orders/tab_basic_info", service_order: @service_order %>
    </turbo-frame>

    <turbo-frame id="service_order_tab_progress" data-tabs-target="panel" data-tab-name="progress" class="hidden">
      <%= render "admin/service_orders/tab_progress", service_order: @service_order %>
    </turbo-frame>

    <turbo-frame id="service_order_tab_photos" data-tabs-target="panel" data-tab-name="photos" class="hidden">
      <%= render "admin/service_orders/tab_photos", service_order: @service_order %>
    </turbo-frame>

    <turbo-frame id="service_order_tab_parts" data-tabs-target="panel" data-tab-name="parts" class="hidden">
      <%= render "admin/service_orders/tab_parts", service_order: @service_order %>
    </turbo-frame>

    <turbo-frame id="service_order_tab_repairs" data-tabs-target="panel" data-tab-name="repairs" class="hidden">
      <%= render "admin/service_orders/tab_repairs", service_order: @service_order %>
    </turbo-frame>
  </div>
</div>
