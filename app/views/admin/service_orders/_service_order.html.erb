<tr id="<%= dom_id(service_order) %>">
  <td class="px-6 py-4 whitespace-nowrap">
    <div class="text-sm font-medium text-gray-900">
      <%= link_to service_order.order_number, admin_service_order_path(service_order), class: "hover:text-indigo-600 transition", data: { turbo_frame: "_top" } %>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= link_to service_order.customer.name, admin_customer_path(service_order.customer), class: "text-indigo-600 hover:text-indigo-900 transition", data: { turbo_frame: "_top" } %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= link_to "#{service_order.bicycle.brand} #{service_order.bicycle.model_label}", admin_bicycle_path(service_order.bicycle), class: "text-indigo-600 hover:text-indigo-900 transition", data: { turbo_frame: "_top" } %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= service_order.service_type.titleize %></span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <% case service_order.status %>
    <% when "received" %>
      <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">Received</span>
    <% when "diagnosis" %>
      <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">Diagnosis</span>
    <% when "in_progress" %>
      <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800">In Progress</span>
    <% when "completed" %>
      <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Completed</span>
    <% when "delivered" %>
      <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800">Delivered</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= service_order.received_at.strftime("%Y-%m-%d") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
    <%= link_to "Edit", edit_admin_service_order_path(service_order), class: "text-indigo-600 hover:text-indigo-900 transition" %>
    <%= button_to "Delete", admin_service_order_path(service_order), method: :delete,
          class: "text-red-600 hover:text-red-900 transition",
          form: { data: { turbo_confirm: "Are you sure you want to delete this service order?" } } %>
  </td>
</tr>
