<% content_for(:title, "칸반보드 - 서비스오더 - Admin - Today Bike") %>

<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">입출고 칸반보드</h1>
    <div class="flex items-center gap-3">
      <%= link_to admin_service_orders_path, class: "inline-flex items-center gap-2 rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        리스트 보기
      <% end %>
      <%= link_to new_admin_service_order_path, class: "inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Service Order
      <% end %>
    </div>
  </div>

  <%
    column_labels = {
      "received" => "접수",
      "diagnosis" => "진단",
      "in_progress" => "작업중",
      "completed" => "완료",
      "delivered" => "출고"
    }

    column_colors = {
      "received" => { bg: "bg-gray-100", text: "text-gray-800", badge: "bg-gray-200" },
      "diagnosis" => { bg: "bg-yellow-50", text: "text-yellow-800", badge: "bg-yellow-200" },
      "in_progress" => { bg: "bg-blue-50", text: "text-blue-800", badge: "bg-blue-200" },
      "completed" => { bg: "bg-green-50", text: "text-green-800", badge: "bg-green-200" },
      "delivered" => { bg: "bg-purple-50", text: "text-purple-800", badge: "bg-purple-200" }
    }

    service_type_colors = {
      "overhaul" => "bg-red-100 text-red-700",
      "repair" => "bg-orange-100 text-orange-700",
      "parts" => "bg-cyan-100 text-cyan-700",
      "upgrade" => "bg-violet-100 text-violet-700",
      "fitting" => "bg-emerald-100 text-emerald-700",
      "frame_change" => "bg-pink-100 text-pink-700"
    }
  %>

  <div class="flex gap-4 overflow-x-auto pb-4" data-testid="kanban-board">
    <% @columns.each do |column| %>
      <% colors = column_colors[column[:value]] %>
      <div class="flex-shrink-0 w-72 flex flex-col" data-testid="kanban-column" data-status="<%= column[:value] %>">
        <%# Column header %>
        <div class="<%= colors[:bg] %> rounded-t-lg px-4 py-3 flex items-center justify-between">
          <h2 class="text-sm font-semibold <%= colors[:text] %>"><%= column_labels[column[:value]] %></h2>
          <span class="<%= colors[:badge] %> <%= colors[:text] %> text-xs font-medium rounded-full px-2 py-0.5" data-testid="column-count">
            <%= column[:orders].size %>
          </span>
        </div>

        <%# Column body %>
        <div class="flex-1 bg-gray-50 rounded-b-lg p-2 space-y-2 min-h-[200px] border border-t-0 border-gray-200">
          <% if column[:orders].empty? %>
            <div class="flex items-center justify-center h-full min-h-[180px]">
              <p class="text-sm text-gray-400">No orders</p>
            </div>
          <% else %>
            <% column[:orders].each do |order| %>
              <%= link_to admin_service_order_path(order), class: "block bg-white rounded-lg shadow-sm border border-gray-200 p-3 hover:shadow-md hover:border-indigo-300 transition group", data: { testid: "kanban-card" } do %>
                <%# Order number %>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-mono font-semibold text-gray-900 group-hover:text-indigo-600 transition"><%= order.order_number %></span>
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= service_type_colors[order.service_type] || 'bg-gray-100 text-gray-700' %>">
                    <%= order.service_type.titleize %>
                  </span>
                </div>

                <%# Customer name %>
                <div class="flex items-center gap-1.5 mb-1">
                  <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span class="text-sm text-gray-700 truncate"><%= order.customer.name %></span>
                </div>

                <%# Bicycle info %>
                <div class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <span class="text-sm text-gray-500 truncate"><%= order.bicycle.brand %> <%= order.bicycle.model_label %></span>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
