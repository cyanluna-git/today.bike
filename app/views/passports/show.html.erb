<% content_for(:title, "#{@bicycle.brand} #{@bicycle.model_label} - Bicycle Passport - Today Bike") %>

<%# Bicycle Info %>
<div class="bg-white shadow rounded-lg overflow-hidden mb-6">
  <div class="px-6 py-4 bg-blue-600">
    <h1 class="text-xl font-bold text-white"><%= @bicycle.brand %> <%= @bicycle.model_label %></h1>
    <p class="text-blue-100 text-sm mt-1">Bicycle Passport</p>
  </div>

  <dl class="divide-y divide-gray-200">
    <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">Brand</dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.brand %></dd>
    </div>
    <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">Model</dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.model_label %></dd>
    </div>
    <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">Type</dt>
      <dd class="mt-1 sm:col-span-2 sm:mt-0">
        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800"><%= @bicycle.bike_type.titleize %></span>
      </dd>
    </div>
    <% if @bicycle.color.present? %>
      <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Color</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.color %></dd>
      </div>
    <% end %>
    <% if @bicycle.year.present? %>
      <div class="px-6 py-3 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500">Year</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @bicycle.year %></dd>
      </div>
    <% end %>
  </dl>
</div>

<%# Specs grouped by category %>
<% grouped = @bicycle.grouped_specs %>
<% if grouped.any? %>
  <div class="mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Component Specs</h2>
    <% grouped.each do |_key, group| %>
      <div class="bg-white shadow rounded-lg overflow-hidden mb-3">
        <div class="px-4 py-2 bg-gray-100 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-700"><%= group[:label] %></h3>
        </div>
        <dl class="divide-y divide-gray-200">
          <% group[:specs].each do |spec| %>
            <div class="px-4 py-2 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500"><%= spec.component.titleize %></dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
                <span class="font-medium"><%= spec.brand %></span> <%= spec.component_model %>
                <% if spec.spec_detail.present? %>
                  <span class="text-gray-500 text-xs block"><%= spec.spec_detail %></span>
                <% end %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>
  </div>
<% end %>

<%# Service History %>
<% orders = @bicycle.service_orders.order(received_at: :desc) %>
<% if orders.any? %>
  <div class="mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Service History</h2>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <ul class="divide-y divide-gray-200">
        <% orders.each do |order| %>
          <li class="px-4 py-3">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= order.order_number %></p>
                <p class="text-xs text-gray-500"><%= order.service_type.titleize %></p>
              </div>
              <div class="text-right">
                <p class="text-xs text-gray-500"><%= order.received_at.strftime("%Y-%m-%d") %></p>
                <% status_colors = { "received" => "bg-gray-100 text-gray-800", "diagnosis" => "bg-yellow-100 text-yellow-800", "in_progress" => "bg-blue-100 text-blue-800", "completed" => "bg-green-100 text-green-800", "delivered" => "bg-purple-100 text-purple-800" } %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= status_colors[order.status] || 'bg-gray-100 text-gray-800' %>">
                  <%= ServiceProgress::STATUS_LABELS[order.status] || order.status.titleize %>
                </span>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>

<%# Fitting Records (latest) %>
<% latest_fitting = @bicycle.fitting_records.order(recorded_at: :desc).first %>
<% if latest_fitting %>
  <div class="mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Latest Fitting Record</h2>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-4 py-2 bg-gray-100 border-b border-gray-200">
        <p class="text-xs text-gray-500">Recorded: <%= latest_fitting.recorded_at.strftime("%Y-%m-%d") %></p>
      </div>
      <dl class="divide-y divide-gray-200">
        <% FittingRecord::MEASUREMENT_FIELDS.each do |field| %>
          <% value = latest_fitting.send(field) %>
          <% next unless value.present? %>
          <div class="px-4 py-2 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500"><%= field.to_s.titleize %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= value %> mm</dd>
          </div>
        <% end %>
        <% if latest_fitting.saddle_brand.present? || latest_fitting.saddle_model.present? %>
          <div class="px-4 py-2 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-500">Saddle</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= [latest_fitting.saddle_brand, latest_fitting.saddle_model].compact.join(" ") %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>
<% end %>
