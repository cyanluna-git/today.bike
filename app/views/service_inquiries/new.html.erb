<% content_for(:title, "문의 및 접수 요청 - Today Bike") %>

<div class="w-full max-w-3xl mx-auto">
  <div class="mb-6">
    <%= link_to(root_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition") do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      홈으로
    <% end %>
  </div>

  <section class="mb-8 rounded-3xl bg-gray-900 px-6 py-8 text-white shadow-sm">
    <p class="text-sm font-medium text-gray-300">Today.bike 접수 창구</p>
    <h1 class="mt-3 text-3xl font-bold">문의나 접수 요청을 남겨주세요.</h1>
    <p class="mt-3 max-w-2xl text-sm text-gray-300">
      문의 유형을 따로 고르지 않아도 됩니다. 현재 보신 페이지 맥락을 함께 저장해서 운영자가 확인합니다.
    </p>

    <div class="mt-5 flex flex-wrap gap-3 text-sm">
      <% if @service_inquiry.product.present? %>
        <span class="inline-flex items-center rounded-full bg-white/10 px-3 py-1.5 text-white">상품 문의: <%= @service_inquiry.product.name %></span>
      <% elsif @service_inquiry.service_type.present? %>
        <span class="inline-flex items-center rounded-full bg-white/10 px-3 py-1.5 text-white">서비스 맥락: <%= @service_inquiry.service_type_label %></span>
      <% elsif @service_inquiry.source_page == "home" %>
        <span class="inline-flex items-center rounded-full bg-white/10 px-3 py-1.5 text-white">홈에서 시작한 문의</span>
      <% end %>
    </div>
  </section>

  <section class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
    <%= form_with model: @service_inquiry, class: "space-y-5" do |form| %>
      <% if @service_inquiry.errors.any? %>
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-700">
          <% @service_inquiry.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form.hidden_field :service_type %>
      <%= form.hidden_field :product_id %>
      <%= form.hidden_field :source_page %>

      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <%= form.label :name, "이름", class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field :name, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "성함을 입력해주세요" %>
        </div>
        <div>
          <%= form.label :phone, "연락처", class: "block text-sm font-medium text-gray-700" %>
          <%= form.telephone_field :phone, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "010-1234-5678" %>
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <%= form.label :email, "이메일", class: "block text-sm font-medium text-gray-700" %>
          <%= form.email_field :email, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "선택 입력" %>
        </div>
        <div>
          <%= form.label :desired_visit_on, "희망 방문일", class: "block text-sm font-medium text-gray-700" %>
          <%= form.date_field :desired_visit_on, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= form.label :message, "문의 내용", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :message, rows: 6, class: "mt-1 block w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "자전거 상태, 원하는 서비스, 궁금한 점, 확인이 필요한 내용 등을 자유롭게 적어주세요." %>
      </div>

      <div class="rounded-2xl bg-gray-50 px-4 py-4 text-sm text-gray-500">
        입력하신 내용은 운영자가 확인 후 연락드립니다. 아직 유형을 확정하지 않아도 괜찮고, 접수 요청과 상담 문의를 함께 적어주셔도 됩니다.
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="text-xs text-gray-400">외부 채팅으로 이동하지 않고 웹 안에서 바로 접수됩니다.</p>
        <%= form.submit "문의 접수하기", class: "inline-flex items-center rounded-full bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" %>
      </div>
    <% end %>
  </section>
</div>
