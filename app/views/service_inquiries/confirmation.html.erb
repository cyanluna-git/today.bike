<% content_for(:title, "문의 접수 완료 - Today Bike") %>

<div class="w-full max-w-2xl mx-auto">
  <section class="rounded-3xl border border-gray-100 bg-white px-6 py-10 text-center shadow-sm">
    <h1 class="text-2xl font-bold text-gray-900">문의가 접수되었습니다.</h1>
    <p class="mt-3 text-gray-600">운영자가 내용을 확인한 뒤 연락드립니다. 추가 정보가 필요하면 접수된 연락처로 안내드릴 예정입니다.</p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <%= link_to "서비스 보기", service_page_path("overhaul"), class: "inline-flex items-center rounded-full bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" %>
      <%= link_to "홈으로", root_path, class: "inline-flex items-center rounded-full border border-gray-300 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition" %>
    </div>
  </section>
</div>
