<% content_for(:title, "Blog - Today Bike") %>

<div class="w-full max-w-6xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Today.bike Blog</h1>
    <p class="mt-2 text-gray-600">Bicycle maintenance tips, repair guides, and shop news.</p>
  </div>

  <%# Category tabs %>
  <div class="mb-6">
    <nav class="flex gap-2 flex-wrap" aria-label="Category filter">
      <%= link_to "All", blog_path, class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:category].blank? ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50'} transition" %>
      <% BlogPost::CATEGORY_LABELS.each do |key, label| %>
        <%= link_to label, blog_path(category: key), class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:category] == key ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50'} transition" %>
      <% end %>
    </nav>
  </div>

  <%# Blog post cards %>
  <% if @blog_posts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @blog_posts.each do |post| %>
        <article class="bg-white shadow rounded-lg overflow-hidden hover:shadow-md transition">
          <% if post.cover_image.attached? %>
            <%= link_to blog_post_path(post.slug) do %>
              <%= image_tag post.cover_image.variant(resize_to_limit: [600, 300]), class: "w-full h-48 object-cover" %>
            <% end %>
          <% else %>
            <%= link_to blog_post_path(post.slug) do %>
              <div class="w-full h-48 bg-gradient-to-br from-indigo-100 to-indigo-50 flex items-center justify-center">
                <svg class="w-12 h-12 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
            <% end %>
          <% end %>

          <div class="p-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800"><%= post.category_label %></span>
              <time class="text-xs text-gray-500" datetime="<%= post.published_at&.iso8601 %>"><%= post.published_at&.strftime("%Y-%m-%d") %></time>
            </div>
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              <%= link_to post.title, blog_post_path(post.slug), class: "hover:text-indigo-600 transition" %>
            </h2>
            <p class="text-sm text-gray-600 line-clamp-3"><%= post.excerpt %></p>
          </div>
        </article>
      <% end %>
    </div>

    <%# Pagination %>
    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
          <% if @pagy.prev %>
            <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" do %>
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" /></svg>
            <% end %>
          <% end %>
          <% @pagy.series.each do |item| %>
            <% case item %>
            <% when Integer %>
              <%= link_to item, pagy_url_for(@pagy, item), class: "relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" %>
            <% when String %>
              <span aria-current="page" class="relative z-10 inline-flex items-center bg-indigo-600 px-4 py-2 text-sm font-semibold text-white"><%= item %></span>
            <% when :gap %>
              <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-700 ring-1 ring-inset ring-gray-300">&hellip;</span>
            <% end %>
          <% end %>
          <% if @pagy.next %>
            <%= link_to pagy_url_for(@pagy, @pagy.next), class: "relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" do %>
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
            <% end %>
          <% end %>
        </nav>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500">No blog posts yet. Check back soon!</p>
    </div>
  <% end %>
</div>
