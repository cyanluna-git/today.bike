<% content_for(:title, "#{@rental.name} - Bike Rental - Today Bike") %>

<div class="w-full max-w-6xl mx-auto">
  <div class="mb-6">
    <%= link_to rentals_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Rentals
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <%# Image Gallery %>
    <div>
      <% if @rental.images.attached? %>
        <div class="space-y-4">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <%= image_tag @rental.images.first.variant(resize_to_limit: [800, 600]), class: "w-full object-contain max-h-96" %>
          </div>
          <% if @rental.images.count > 1 %>
            <div class="grid grid-cols-4 gap-2">
              <% @rental.images.each do |image| %>
                <div class="bg-white shadow rounded overflow-hidden">
                  <%= image_tag image.variant(resize_to_limit: [200, 200]), class: "w-full h-20 object-cover" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gradient-to-br from-green-100 to-green-50 rounded-lg flex items-center justify-center h-96">
          <svg class="w-24 h-24 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
      <% end %>
    </div>

    <%# Rental Details + Booking Form %>
    <div>
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800"><%= @rental.rental_type_label %></span>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @rental.name %></h1>

      <div class="mb-6">
        <span class="font-bold text-3xl text-gray-900"><%= number_to_currency(@rental.daily_rate, unit: "₩", precision: 0) %></span>
        <span class="text-gray-500">/day</span>
      </div>

      <% if @rental.description.present? %>
        <div class="prose max-w-none text-gray-700 mb-6">
          <%= simple_format(@rental.description) %>
        </div>
      <% end %>

      <%# Booking Form %>
      <div class="bg-white shadow rounded-lg p-6 mt-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Reserve This Bike</h2>

        <%= form_with(model: @rental_booking, url: create_booking_rental_path(@rental), class: "space-y-4") do |form| %>
          <% if @rental_booking.errors.any? %>
            <div class="rounded-md bg-red-50 p-4">
              <ul class="list-disc list-inside text-sm text-red-700">
                <% @rental_booking.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div>
            <%= form.label :guest_name, "Name", class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :guest_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, placeholder: "Your name" %>
          </div>

          <div>
            <%= form.label :guest_phone, "Phone", class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :guest_phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, placeholder: "010-0000-0000" %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label :start_date, "Start Date", class: "block text-sm font-medium text-gray-700" %>
              <%= form.date_field :start_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, min: Date.current %>
            </div>

            <div>
              <%= form.label :end_date, "End Date", class: "block text-sm font-medium text-gray-700" %>
              <%= form.date_field :end_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, min: Date.current + 1 %>
            </div>
          </div>

          <% if @booked_dates.any? %>
            <div class="rounded-md bg-yellow-50 p-3">
              <p class="text-sm text-yellow-800">
                <strong>Booked dates:</strong>
                <%= @booked_dates.sort.map { |d| d.strftime("%m/%d") }.join(", ") %>
              </p>
            </div>
          <% end %>

          <div>
            <%= form.submit "Reserve", class: "w-full rounded-md bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
