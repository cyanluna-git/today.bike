#!/usr/bin/env bash
set -euo pipefail

APP="today-bike"
SERVER="ubuntu@217.142.238.243"
IMAGE="today-bike:latest"
REGISTRY="ghcr.io/cyanluna-git"
REMOTE_IMAGE="$REGISTRY/today-bike:latest"
MASTER_KEY_FILE="config/master.key"
APP_HOST="todaybike.cyanluna.com"
APP_PROTOCOL="https"
APP_PORT="3000"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step() { echo -e "\n${YELLOW}▸ $1${NC}"; }
ok()   { echo -e "${GREEN}✓ $1${NC}"; }
fail() { echo -e "${RED}✗ $1${NC}"; exit 1; }

# Pre-flight checks
[ -f "$MASTER_KEY_FILE" ] || fail "master.key not found at $MASTER_KEY_FILE"
MASTER_KEY=$(cat "$MASTER_KEY_FILE")
[ -n "${GHCR_TOKEN:-}" ] || fail "GHCR_TOKEN not set — export GHCR_TOKEN=<your-github-pat> (needs packages:write scope)"

# 1. Login to ghcr.io
step "Logging in to ghcr.io..."
echo "$GHCR_TOKEN" | docker login ghcr.io -u cyanluna-git --password-stdin
ok "Logged in to ghcr.io"

# 2. Build
step "Building Docker image (linux/amd64)..."
docker build --platform linux/amd64 -t "$IMAGE" . 2>&1 | tail -5
ok "Image built"

# 3. Push to registry
step "Pushing image to ghcr.io..."
docker tag "$IMAGE" "$REMOTE_IMAGE"
docker push "$REMOTE_IMAGE"
ok "Image pushed"

# 4. Pull on server
step "Pulling image on server..."
ssh "$SERVER" "echo '$GHCR_TOKEN' | docker login ghcr.io -u cyanluna-git --password-stdin && docker pull '$REMOTE_IMAGE'"
ok "Image pulled on server"

# 5. Restart container
step "Restarting container..."
ssh "$SERVER" "docker stop $APP 2>/dev/null; docker rm $APP 2>/dev/null; true"
ssh "$SERVER" "docker run -d \
  --name $APP \
  --restart unless-stopped \
  -p 127.0.0.1:${APP_PORT}:80 \
  -v ${APP}_storage:/rails/storage \
  -e RAILS_MASTER_KEY=$MASTER_KEY \
  -e RAILS_SERVE_STATIC_FILES=true \
  -e SOLID_QUEUE_IN_PUMA=true \
  -e APP_HOST=$APP_HOST \
  -e APP_PROTOCOL=$APP_PROTOCOL \
  -e APP_BASE_URL=${APP_PROTOCOL}://$APP_HOST \
  $REMOTE_IMAGE" > /dev/null
ok "Container started"

# 6. Ensure nginx is serving the configured host
step "Reloading nginx..."
ssh "$SERVER" "sudo systemctl reload nginx || sudo systemctl restart nginx"
ok "Nginx reloaded"

# 7. Health check through nginx (wait for Puma boot)
step "Health check..."
for i in $(seq 1 10); do
  STATUS=$(ssh "$SERVER" "curl -s -o /dev/null -w '%{http_code}' -H 'Host: $APP_HOST' http://127.0.0.1/" 2>/dev/null || echo "000")
  if [ "$STATUS" = "200" ]; then
    ok "Nginx reverse proxy responding HTTP 200"
    echo -e "\n${GREEN}Deploy complete!${NC}"
    exit 0
  fi
  sleep 2
done
fail "Health check failed (last status: $STATUS). Check logs: ssh $SERVER 'docker logs $APP --tail 30'"
